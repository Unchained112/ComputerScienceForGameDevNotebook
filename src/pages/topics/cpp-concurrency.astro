    <!-- condition_variable & future -->
    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">condition_variable 与 future</span><span slot="en">condition_variable & future</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh"><b>condition_variable</b> 实现线程间<b>等待-通知</b>——消费者等待条件满足，生产者通知唤醒。是生产者-消费者模式的核心。<b>future/promise</b> 实现异步结果传递——<code>std::async</code> 启动异步任务并返回 <code>future</code>，调用 <code>get()</code> 阻塞等待结果。</span><span slot="en"><b>condition_variable</b> implements inter-thread <b>wait-notify</b> — consumers wait for a condition, producers notify to wake them. Core of the producer-consumer pattern. <b>future/promise</b> implements async result passing — <code>std::async</code> launches an async task returning a <code>future</code>; calling <code>get()</code> blocks for the result.</span></Bilingual></p>
      <CodeTabs
  cpp={`<pre><code>#include &lt;condition_variable&gt;
#include &lt;future&gt;
#include &lt;queue&gt;

// ===== 生产者-消费者 =====
std::queue&lt;int&gt; taskQueue;
std::mutex queueMtx;
std::condition_variable queueCV;
bool done = false;

// 生产者
void producer() &#123;
    for (int i = 0; i &lt; 10; i++) &#123;
        &#123;
            std::lock_guard lock(queueMtx);
            taskQueue.push(i);
            std::cout &lt;&lt; "Produced " &lt;&lt; i &lt;&lt; "\\n";
        &#125;
        queueCV.notify_one();   // 通知一个等待的消费者
    &#125;
    &#123;
        std::lock_guard lock(queueMtx);
        done = true;
    &#125;
    queueCV.notify_one();
&#125;

// 消费者
void consumer() &#123;
    while (true) &#123;
        int task;
        &#123;
            std::unique_lock lock(queueMtx);
            queueCV.wait(lock, []&#123;
                return !taskQueue.empty() || done;
            &#125;);   // 等待：自动释放锁，被唤醒后重新加锁
            if (taskQueue.empty() &amp;&amp; done) return;
            task = taskQueue.front();
            taskQueue.pop();
        &#125;
        std::cout &lt;&lt; "Consumed " &lt;&lt; task &lt;&lt; "\\n";
    &#125;
&#125;

// ===== future / promise / async =====
// std::async：最简单的异步任务
std::future&lt;int&gt; fut = std::async(std::launch::async, []() &#123;
    std::this_thread::sleep_for(std::chrono::seconds(1));
    return 42;
&#125;);
// 主线程做其他事...
int result = fut.get();   // 阻塞等待结果（= 42）

// std::promise / future：手动设置结果
std::promise&lt;int&gt; prom;
std::future&lt;int&gt; fut2 = prom.get_future();
std::thread t([&amp;prom]() &#123;
    int result = computeExpensive();
    prom.set_value(result);   // 设置结果
&#125;);
int val = fut2.get();         // 等待结果
t.join();

// std::packaged_task：包装可调用对象
std::packaged_task&lt;int(int)&gt; task([](int x) &#123; return x * 2; &#125;);
std::future&lt;int&gt; fut3 = task.get_future();
std::thread t2(std::move(task), 21);
int val2 = fut3.get();   // = 42
t2.join();

// 游戏场景：异步资源加载
class AssetLoader &#123;
    std::unordered_map&lt;std::string, std::future&lt;Texture&gt;&gt; loading;
public:
    void requestAsync(const std::string&amp; path) &#123;
        loading[path] = std::async(std::launch::async, [path]() &#123;
            return loadTexture(path);   // 耗时加载
        &#125;);
    &#125;
    Texture* getIfReady(const std::string&amp; path) &#123;
        auto it = loading.find(path);
        if (it != loading.end() &amp;&amp;
            it-&gt;second.wait_for(std::chrono::seconds(0)) ==
            std::future_status::ready) &#123;
            return &amp;it-&gt;second.get();
        &#125;
        return nullptr;   // 还没加载完
    &#125;
&#125;;</code></pre>`}
  py={`<pre><code>import threading, queue, concurrent.futures

# ===== 生产者-消费者 =====
task_queue = queue.Queue()

def producer():
    for i in range(10):
        task_queue.put(i)
        print(f"Produced {i}")
    task_queue.put(None)  # 结束信号

def consumer():
    while True:
        task = task_queue.get()  # 阻塞等待
        if task is None:
            break
        print(f"Consumed {task}")
        task_queue.task_done()

# 启动
pt = threading.Thread(target=producer)
ct = threading.Thread(target=consumer)
pt.start(); ct.start()
pt.join(); ct.join()

# ===== future（concurrent.futures） =====
from concurrent.futures import ThreadPoolExecutor

with ThreadPoolExecutor() as pool:
    # 提交异步任务
    fut = pool.submit(lambda: (
        __import__('time').sleep(1), 42)[1])
    # 主线程做其他事...
    result = fut.result()  # 阻塞等待（= 42）
    print(result)

# Future 模式
from concurrent.futures import Future

def async_load(path):
    """异步加载资源"""
    fut = Future()
    def work():
        try:
            result = load_texture(path)
            fut.set_result(result)
        except Exception as e:
            fut.set_exception(e)
    threading.Thread(target=work).start()
    return fut

fut = async_load("hero.png")
# 做其他事...
if fut.done():
    tex = fut.result()
else:
    print("still loading...")</code></pre>`}
