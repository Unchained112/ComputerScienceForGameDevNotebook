<script>
  // 生产者-消费者时序图动画
  const SVGNS = 'http://www.w3.org/2000/svg';
  const svg = document.getElementById('pc-svg') as unknown as SVGSVGElement;
  const stateEl = document.getElementById('pc-state');

  const LANES = [
    { x: 120, label: { zh: '生产者', en: 'Producer' } },
    { x: 400, label: { zh: '队列+锁', en: 'Queue+Mutex' } },
    { x: 680, label: { zh: '消费者', en: 'Consumer' } },
  ];
  const TOP = 60, BOT = 320;
  const COL = {
    PROD: '#22C55E',
    CONS: '#22D3EE',
    MUTEX: '#FBBF24',
    WAIT: '#A78BFA',
    TXT: '#CBD5E1',
    LBL: '#94A3B8',
    BG: 'rgba(148,163,184,0.15)',
    LINE: 'rgba(148,163,184,0.3)',
  };

  interface Step { from: number; to: number; labelZh: string; labelEn: string; color: string; }
  const STEPS: Step[] = [
    { from: 0, to: 1, labelZh: '1. lock(mtx)', labelEn: '1. lock(mtx)', color: COL.MUTEX },
    { from: 0, to: 1, labelZh: '2. queue.push(item)', labelEn: '2. queue.push(item)', color: COL.PROD },
    { from: 0, to: 1, labelZh: '3. unlock(mtx)', labelEn: '3. unlock(mtx)', color: COL.MUTEX },
    { from: 0, to: 1, labelZh: '4. cv.notify_one()', labelEn: '4. cv.notify_one()', color: COL.PROD },
    { from: 2, to: 1, labelZh: '5. cv.wait(lock,[])', labelEn: '5. cv.wait(lock,[])', color: COL.WAIT },
    { from: 1, to: 2, labelZh: '6. 唤醒消费者', labelEn: '6. wake consumer', color: COL.WAIT },
    { from: 2, to: 1, labelZh: '7. lock(mtx)', labelEn: '7. lock(mtx)', color: COL.MUTEX },
    { from: 1, to: 2, labelZh: '8. queue.pop(item)', labelEn: '8. queue.pop(item)', color: COL.CONS },
    { from: 2, to: 1, labelZh: '9. unlock(mtx)', labelEn: '9. unlock(mtx)', color: COL.MUTEX },
    { from: 2, to: 2, labelZh: '10. 处理 item', labelEn: '10. process item', color: COL.CONS },
  ];

  let curStepIdx = -1;
  function lang(): 'zh' | 'en' { return document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh'; }

  function render(stepIdx: number) {
    curStepIdx = stepIdx;
    svg.innerHTML = '';

    // 泳道
    for (const lane of LANES) {
      const rect = document.createElementNS(SVGNS, 'rect');
      rect.setAttribute('x', String(lane.x - 90));
      rect.setAttribute('y', String(TOP - 30));
      rect.setAttribute('width', '180'); rect.setAttribute('height', String(BOT - TOP + 60));
      rect.setAttribute('fill', COL.BG); rect.setAttribute('rx', '8');
      svg.appendChild(rect);

      const line = document.createElementNS(SVGNS, 'line');
      line.setAttribute('x1', String(lane.x)); line.setAttribute('y1', String(TOP));
      line.setAttribute('x2', String(lane.x)); line.setAttribute('y2', String(BOT));
      line.setAttribute('stroke', COL.LINE); line.setAttribute('stroke-width', '1.5');
      line.setAttribute('stroke-dasharray', '4 4');
      svg.appendChild(line);

      const t = document.createElementNS(SVGNS, 'text');
      t.setAttribute('x', String(lane.x)); t.setAttribute('y', String(TOP - 12));
      t.setAttribute('text-anchor', 'middle'); t.setAttribute('font-size', '13');
      t.setAttribute('font-weight', '600'); t.setAttribute('fill', '#E2E8F0');
      t.textContent = lang() === 'en' ? lane.label.en : lane.label.zh;
      svg.appendChild(t);
    }

    // 步骤箭头
    const yStart = TOP + 20;
    const yStep = (BOT - TOP - 40) / STEPS.length;
    for (let i = 0; i <= stepIdx && i < STEPS.length; i++) {
      const s = STEPS[i];
      const y = yStart + i * yStep;
      const x1 = LANES[s.from].x, x2 = LANES[s.to].x;
      const isActive = i === stepIdx;
      const color = isActive ? s.color : 'rgba(148,163,184,0.35)';

      if (x1 !== x2) {
        const line = document.createElementNS(SVGNS, 'line');
        line.setAttribute('x1', String(x1)); line.setAttribute('y1', String(y));
        line.setAttribute('x2', String(x2)); line.setAttribute('y2', String(y));
        line.setAttribute('stroke', color);
        line.setAttribute('stroke-width', isActive ? '2.5' : '1.5');
        svg.appendChild(line);

        const dir = x2 > x1 ? 1 : -1;
        const tri = document.createElementNS(SVGNS, 'polygon');
        tri.setAttribute('points', `${x2},${y} ${x2 - dir * 8},${y - 5} ${x2 - dir * 8},${y + 5}`);
        tri.setAttribute('fill', color);
        svg.appendChild(tri);

        const midX = (x1 + x2) / 2;
        const lbl = document.createElementNS(SVGNS, 'text');
        lbl.setAttribute('x', String(midX)); lbl.setAttribute('y', String(y - 8));
        lbl.setAttribute('text-anchor', 'middle'); lbl.setAttribute('font-size', '11');
        lbl.setAttribute('fill', isActive ? color : COL.LBL);
        if (isActive) lbl.setAttribute('font-weight', '700');
        lbl.textContent = lang() === 'en' ? s.labelEn : s.labelZh;
        svg.appendChild(lbl);
      } else {
        // 自环（处理 item）
        const circ = document.createElementNS(SVGNS, 'circle');
        circ.setAttribute('cx', String(x1)); circ.setAttribute('cy', String(y));
        circ.setAttribute('r', '12');
        circ.setAttribute('fill', 'none'); circ.setAttribute('stroke', color);
        circ.setAttribute('stroke-width', isActive ? '2.5' : '1.5');
        svg.appendChild(circ);

        const lbl = document.createElementNS(SVGNS, 'text');
        lbl.setAttribute('x', String(x1 + 20)); lbl.setAttribute('y', String(y + 4));
        lbl.setAttribute('font-size', '11'); lbl.setAttribute('fill', isActive ? color : COL.LBL);
        if (isActive) lbl.setAttribute('font-weight', '700');
        lbl.textContent = lang() === 'en' ? s.labelEn : s.labelZh;
        svg.appendChild(lbl);
      }

      if (isActive) {
        for (const li of [s.from, s.to]) {
          const bar = document.createElementNS(SVGNS, 'rect');
          bar.setAttribute('x', String(LANES[li].x - 3));
          bar.setAttribute('y', String(y - 8));
          bar.setAttribute('width', '6'); bar.setAttribute('height', '16');
          bar.setAttribute('fill', color); bar.setAttribute('rx', '2');
          bar.setAttribute('opacity', '0.6');
          svg.appendChild(bar);
        }
      }
    }

    if (stateEl) {
      if (stepIdx >= 0 && stepIdx < STEPS.length) {
        const s = STEPS[stepIdx];
        stateEl.textContent = lang() === 'en' ? s.labelEn : s.labelZh;
      } else {
        stateEl.textContent = lang() === 'en' ? 'Ready' : '就绪';
      }
    }
  }

  let idx = 0;
  let timer: number | null = null;
  function langText(key: string): string {
    const l = lang();
    const el = document.querySelector(`[data-ui="${key}"][data-lang="${l}"]`);
    return el ? (el.textContent || '') : '';
  }
  function stop() {
    if (timer !== null) { clearInterval(timer); timer = null; }
    const b = document.getElementById('pc-play');
    if (b) b.innerHTML = langText('play');
  }
  function rebuild() {
    stop(); idx = 0; render(-1); if (stateEl) stateEl.textContent = '';
  }
  function advance(): boolean {
    if (idx < STEPS.length) { render(idx); idx++; return true; }
    return false;
  }
  function play() {
    if (timer !== null) { stop(); return; }
    const b = document.getElementById('pc-play');
    if (b) b.innerHTML = langText('pause');
    timer = window.setInterval(() => { if (!advance()) stop(); }, 900);
  }

  document.getElementById('pc-play')?.addEventListener('click', play);
  document.getElementById('pc-step')?.addEventListener('click', () => { stop(); advance(); });
  document.getElementById('pc-reset')?.addEventListener('click', rebuild);
  document.addEventListener('langchange', () => {
    if (timer === null) { const b = document.getElementById('pc-play'); if (b) b.innerHTML = langText('play'); }
    if (curStepIdx >= 0) render(curStepIdx); else render(-1);
  });
  rebuild();
</script>
