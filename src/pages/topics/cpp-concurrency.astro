    <!-- atomic 与内存序 -->
    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">atomic 与内存序</span><span slot="en">Atomic & Memory Order</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh"><code>std::atomic</code> 提供<b>无锁原子操作</b>——读-改-写不可中断，无需互斥锁。<code>memory_order</code> 控制可见性：<b>seq_cst</b>（默认，最强，全局顺序）、<b>acquire/release</b>（成对使用，保证释放-获取语义）、<b>relaxed</b>（最弱，仅原子性无顺序保证）。游戏开发中，<code>atomic&lt;bool&gt;</code> 做停止标志、<code>atomic&lt;int&gt;</code> 做计数器，性能远高于 mutex。</span><span slot="en"><code>std::atomic</code> provides <b>lock-free atomic operations</b> — uninterruptible read-modify-write, no mutex needed. <code>memory_order</code> controls visibility: <b>seq_cst</b> (default, strongest, global order), <b>acquire/release</b> (paired, release-acquire semantics), <b>relaxed</b> (weakest, atomicity only, no ordering). In game dev, <code>atomic&lt;bool&gt;</code> for stop flags, <code>atomic&lt;int&gt;</code> for counters — far faster than mutex.</span></Bilingual></p>
      <CodeTabs
  cpp={`<pre><code>#include &lt;atomic&gt;

// ===== 基本原子类型 =====
std::atomic&lt;int&gt; counter(0);
std::atomic&lt;bool&gt; running(true);
std::atomic&lt;uint32_t&gt; frameCount(0);

// 原子操作
counter.fetch_add(1);       // ++counter（原子）
counter.load();             // 读取
counter.store(42);          // 写入
bool expected = false;
running.compare_exchange_strong(expected, true);  // CAS

// ===== 数据竞争 vs 原子 =====
// 错误：数据竞争（UB）
int bad_counter = 0;
// 线程A: bad_counter++;  ← 读-改-写三步，可能交错
// 线程B: bad_counter++;

// 正确：原子操作
std::atomic&lt;int&gt; good_counter(0);
// 线程A: good_counter.fetch_add(1);  ← 原子不可分
// 线程B: good_counter.fetch_add(1);

// ===== 内存序 =====
std::atomic&lt;int&gt; data(0);
std::atomic&lt;bool&gt; ready(false);

// 生产者
void producer() &#123;
    data.store(42, std::memory_order_relaxed);       // 无顺序保证
    ready.store(true, std::memory_order_release);     // 释放：之前的写对获取者可见
&#125;

// 消费者
void consumer() &#123;
    while (!ready.load(std::memory_order_acquire)) &#123;  // 获取：看到释放后的数据
        std::this_thread::yield();
    &#125;
    assert(data.load(std::memory_order_relaxed) == 42);  // 保证看到 42
&#125;

// 内存序对比：
// seq_cst:    全局顺序，最强，最慢（默认）
// acquire:    读操作——看到对应 release 之前的所有写
// release:    写操作——此前的所有写对 acquire 可见
// relaxed:    仅原子性，无顺序保证，最快
// acq_rel:    同时是 acquire 和 release（RMW 操作）

// ===== CAS（Compare-And-Swap）无锁编程 =====
std::atomic&lt;int&gt; value(0);

bool tryIncrement() &#123;
    int old = value.load(std::memory_order_relaxed);
    while (!value.compare_exchange_weak(
        old, old + 1,
        std::memory_order_acq_rel,
        std::memory_order_relaxed)) &#123;
        // CAS 失败：old 被更新为当前值，重试
    &#125;
    return true;
&#125;

// 无锁栈（游戏对象池）
template &lt;typename T&gt;
class LockFreeStack &#123;
    struct Node &#123; T data; Node* next; &#125;;
    std::atomic&lt;Node*&gt; head&#123;nullptr&#125;;
public:
    void push(T value) &#123;
        Node* n = new Node&#123;std::move(value), nullptr&#125;;
        n-&gt;next = head.load(std::memory_order_relaxed);
        while (!head.compare_exchange_weak(
            n-&gt;next, n,
            std::memory_order_release,
            std::memory_order_relaxed));
    &#125;
    bool pop(T&amp; result) &#123;
        Node* old = head.load(std::memory_order_acquire);
        while (old &amp;&amp; !head.compare_exchange_weak(
            old, old-&gt;next,
            std::memory_order_acquire,
            std::memory_order_relaxed));
        if (old) &#123; result = std::move(old-&gt;data); delete old; return true; &#125;
        return false;
    &#125;
&#125;;</code></pre>`}
