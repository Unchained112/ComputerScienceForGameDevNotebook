    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">std::thread：创建与管理</span><span slot="en">std::thread: Creation & Management</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh"><code>std::thread</code> 创建一个 OS 线程。关键规则：<b>必须 <code>join()</code> 或 <code>detach()</code></b>，否则析构时调用 <code>std::terminate</code>。<code>join</code> 等待线程结束（阻塞），<code>detach</code> 分离（后台运行）。C++20 的 <code>std::jthread</code> 自动 join 并支持<b>协作式取消</b>（<code>stop_token</code>）。</span><span slot="en"><code>std::thread</code> creates an OS thread. Key rule: <b>must <code>join()</code> or <code>detach()</code></b>, else <code>std::terminate</code> is called on destruction. <code>join</code> waits for completion (blocking), <code>detach</code> separates (background). C++20's <code>std::jthread</code> auto-joins and supports <b>cooperative cancellation</b> (<code>stop_token</code>).</span></Bilingual></p>
      <CodeTabs
  cpp={`<pre><code>#include &lt;thread&gt;
#include &lt;iostream&gt;

void worker(int id) &#123;
    std::cout &lt;&lt; "Thread " &lt;&lt; id &lt;&lt; " running\\n";
&#125;

int main() &#123;
    // 创建并启动线程
    std::thread t1(worker, 1);
    std::thread t2([]() &#123;            // Lambda 线程
        std::cout &lt;&lt; "Lambda thread\\n";
    &#125;);

    t1.join();    // 等待 t1 结束
    t2.join();    // 等待 t2 结束
    // 若不 join/detach，t 析构时 std::terminate！

    // detach：后台运行（失去控制）
    std::thread t3([]() &#123; /* background */ &#125;);
    t3.detach();   // 分离，不再可控

    // 线程数：硬件并发数
    unsigned n = std::thread::hardware_concurrency();
    // 通常 = CPU 逻辑核心数（8/16/32...）

    // ===== C++20: std::jthread（自动 join + 可取消） =====
    #include &lt;stop_token&gt;
    std::jtask jt([](std::stop_token st) &#123;
        while (!st.stop_requested()) &#123;
            // 工作循环
            std::this_thread::sleep_for(std::chrono::milliseconds(100));
        &#125;
    &#125;);
    // jt 析构时自动 join（无需手动）
    jt.request_stop();   // 请求停止

    // ===== 传递引用：必须用 std::ref =====
    int result = 0;
    std::thread t4([](int&amp; r) &#123; r = 42; &#125;, std::ref(result));
    t4.join();
    // result == 42

    // ===== 线程池模式（游戏引擎标准） =====
    class ThreadPool &#123;
        std::vector&lt;std::thread&gt; workers;
        std::queue&lt;std::function&lt;void()&gt;&gt; tasks;
        std::mutex mtx;
        std::condition_variable cv;
        bool stop = false;
    public:
        ThreadPool(int n) &#123;
            for (int i = 0; i &lt; n; i++)
                workers.emplace_back([this] &#123;
                    while (true) &#123;
                        std::function&lt;void()&gt; task;
                        &#123;
                            std::unique_lock lock(mtx);
                            cv.wait(lock, [this] &#123; return stop || !tasks.empty(); &#125;);
                            if (stop &amp;&amp; tasks.empty()) return;
                            task = std::move(tasks.front());
                            tasks.pop();
                        &#125;
                        task();
                    &#125;
                &#125;);
        &#125;
        ~ThreadPool() &#123;
            &#123; std::lock_guard lock(mtx); stop = true; &#125;
            cv.notify_all();
            for (auto&amp; w : workers) w.join();
        &#125;
        void enqueue(std::function&lt;void()&gt; task) &#123;
            &#123; std::lock_guard lock(mtx); tasks.push(std::move(task)); &#125;
            cv.notify_one();
        &#125;
    &#125;;</code></pre>`}
