    <!-- mutex / lock -->
    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">互斥锁与锁保护</span><span slot="en">Mutexes & Lock Guards</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh"><b>互斥锁</b>（mutex）保护共享数据——同一时刻只有一个线程能持有锁。<code>std::lock_guard</code> 是 RAII 锁（构造加锁、析构解锁），<code>std::unique_lock</code> 更灵活（可延迟加锁、手动解锁、配合 condition_variable）。<code>std::shared_mutex</code>（C++17）实现<b>读写锁</b>——多读单写。</span><span slot="en"><b>Mutex</b> protects shared data — only one thread can hold it at a time. <code>std::lock_guard</code> is RAII locking (lock on construct, unlock on destruct); <code>std::unique_lock</code> is more flexible (deferred lock, manual unlock, works with condition_variable). <code>std::shared_mutex</code> (C++17) implements a <b>read-write lock</b> — multiple readers, single writer.</span></Bilingual></p>
      <CodeTabs
  cpp={`<pre><code>#include &lt;mutex&gt;
#include &lt;shared_mutex&gt;

std::vector&lt;Entity&gt; entities;   // 共享数据
std::mutex mtx;                   // 保护 entities

// ===== lock_guard：最简单的 RAII 锁 =====
void addEntity(const Entity&amp; e) &#123;
    std::lock_guard lock(mtx);    // 构造时加锁
    entities.push_back(e);
&#125;  // 析构自动解锁（即使异常）

// ===== unique_lock：灵活，可配合 cv =====
void waitForData() &#123;
    std::unique_lock lock(mtx);   // 加锁
    cv.wait(lock, []&#123; return !entities.empty(); &#125;);  // 等待并临时释放锁
    // 重新加锁，继续
    process(entities.back());
&#125;  // 析构解锁

// ===== shared_mutex：读写锁（多读单写） =====
std::shared_mutex rwMtx;

// 读操作：多个线程可同时读
Entity getEntity(size_t i) &#123;
    std::shared_lock lock(rwMtx);   // 共享锁（读锁）
    return entities[i];
&#125;

// 写操作：独占，排斥所有其他读写
void removeEntity(size_t i) &#123;
    std::unique_lock lock(rwMtx);   // 独占锁（写锁）
    entities.erase(entities.begin() + i);
&#125;

// ===== 死锁与避免 =====
// 死锁：两个线程互相等待对方的锁
std::mutex m1, m2;
// 线程A: lock(m1); lock(m2);  ← 等待 m2
// 线程B: lock(m2); lock(m1);  ← 等待 m1
// → 永久阻塞！

// 解决1: 固定加锁顺序
void safeAB() &#123;
    std::lock_guard l1(m1);   // 总是先锁 m1
    std::lock_guard l2(m2);   // 再锁 m2
&#125;

// 解决2: std::lock 一次锁多个（避免死锁）
void safeMulti() &#123;
    std::unique_lock l1(m1, std::defer_lock);
    std::unique_lock l2(m2, std::defer_lock);
    std::lock(l1, l2);   // 原子地锁两个
&#125;

// 解决3: C++17 std::scoped_lock
void safeScoped() &#123;
    std::scoped_lock lock(m1, m2);   // 一次锁多个，RAII
&#125;</code></pre>`}
