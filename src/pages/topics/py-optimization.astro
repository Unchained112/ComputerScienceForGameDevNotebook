    },
    struct: {
      titleZh: '存 1 万个实体(x,y,z,hp)', titleEn: '10k entities (x,y,z,hp)',
      rows: [
        { label: 'C++ SoA (float+int)', bytes: 160000, color: '#22C55E', noteZh: '4×4B × 10000，连续可SIMD', noteEn: '4×4B × 10k, contiguous SIMD' },
        { label: 'C++ vector<Entity>', bytes: 160024, color: '#22D3EE', noteZh: 'DoA，16B×10000', noteEn: 'AoS, 16B × 10k' },
        { label: 'Python dict/list', bytes: 2300000, color: '#FBBF24', noteZh: '10000×(dict232B + 4个对象)', noteEn: '10k×(dict232B + 4 objs)' },
        { label: 'dataclass(slots) list', bytes: 560000, color: '#F472B6', noteZh: '10000×56B，无__dict__', noteEn: '10k×56B, no __dict__' },
        { label: 'numpy SoA', bytes: 170000, color: '#A78BFA', noteZh: 'pos(12B)+hp(4B)×10000', noteEn: 'pos(12B)+hp(4B)×10k' },
      ],
      noteZh: 'dict 方案比 C++ 贵 14 倍；dataclass+numpy 逼近 C++。',
      noteEn: 'dict is 14x C++; dataclass+numpy approaches C++.',
    },
    array: {
      titleZh: '10 万元素数组', titleEn: '100k-element array',
      rows: [
        { label: 'C double[100k]', bytes: 800000, color: '#22C55E', noteZh: '8B × 100000', noteEn: '8B × 100k' },
        { label: 'Python list[float]', bytes: 3640056, color: '#FBBF24', noteZh: '100k×24B对象 + 100k×8B指针 + 56B', noteEn: '100k×24B objs + 100k×8B ptrs + 56B' },
        { label: 'array.array(d)', bytes: 800072, color: '#22D3EE', noteZh: '紧凑 C double 数组 + 头', noteEn: 'compact C doubles + header' },
        { label: 'numpy float64[100k]', bytes: 800128, color: '#A78BFA', noteZh: '连续，仅 +128B 头', noteEn: 'contiguous, only +128B header' },
      ],
      noteZh: 'list 比 C 贵 4.5 倍；array/numpy 与 C 几乎相同。',
      noteEn: 'list is 4.5x C; array/numpy match C almost exactly.',
    },
  };

  function lang(): 'zh' | 'en' { return document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh'; }

  function render(key: string) {
    const data = CASES[key];
    if (!data) return;
    svg.innerHTML = '';

    const title = document.createElementNS(SVGNS, 'text');
    title.setAttribute('x', '20'); title.setAttribute('y', '22');
    title.setAttribute('font-size', '15'); title.setAttribute('font-weight', '700');
    title.setAttribute('fill', '#22D3EE');
    title.textContent = lang() === 'en' ? data.titleEn : data.titleZh;
    svg.appendChild(title);

    const maxBytes = Math.max(...data.rows.map(r => r.bytes));
    const barX = 180, barMaxW = 480, baseY = 45, rowH = 38;

    for (let i = 0; i < data.rows.length; i++) {
      const r = data.rows[i];
      const y = baseY + i * rowH;
      const w = Math.max(4, (r.bytes / maxBytes) * barMaxW);

      const label = document.createElementNS(SVGNS, 'text');
      label.setAttribute('x', '20'); label.setAttribute('y', String(y + 14));
      label.setAttribute('font-size', '11'); label.setAttribute('font-weight', '600');
      label.setAttribute('fill', r.color); label.setAttribute('font-family', 'monospace');
      label.textContent = r.label;
      svg.appendChild(label);

      const bar = document.createElementNS(SVGNS, 'rect');
      bar.setAttribute('x', String(barX)); bar.setAttribute('y', String(y + 2));
      bar.setAttribute('width', String(w)); bar.setAttribute('height', '18');
      bar.setAttribute('rx', '3'); bar.setAttribute('fill', r.color + 'cc');
      svg.appendChild(bar);

      const kb = r.bytes >= 1024 ? (r.bytes / 1024).toFixed(0) + ' KB' : r.bytes + ' B';
      const sz = document.createElementNS(SVGNS, 'text');
      sz.setAttribute('x', String(barX + w + 8)); sz.setAttribute('y', String(y + 16));
      sz.setAttribute('font-size', '11'); sz.setAttribute('fill', '#CBD5E1');
      sz.setAttribute('font-family', 'monospace'); sz.textContent = kb;
      svg.appendChild(sz);

      const note = document.createElementNS(SVGNS, 'text');
      note.setAttribute('x', String(barX)); note.setAttribute('y', String(y + 30));
      note.setAttribute('font-size', '9'); note.setAttribute('fill', '#64748B');
      note.textContent = lang() === 'en' ? r.noteEn : r.noteZh;
      svg.appendChild(note);
    }

    const noteY = baseY + data.rows.length * rowH + 8;
    const note = document.createElementNS(SVGNS, 'text');
    note.setAttribute('x', '20'); note.setAttribute('y', String(noteY));
    note.setAttribute('font-size', '11'); note.setAttribute('fill', '#F472B6');
    note.setAttribute('font-weight', '600');
    note.textContent = lang() === 'en' ? data.noteEn : data.noteZh;
    svg.appendChild(note);
  }

  function setActive(key: string) {
    mcBtns.forEach(b => b.classList.toggle('btn-primary', b.dataset.case === key));
    render(key);
  }
  mcBtns.forEach(b => b.addEventListener('click', () => setActive(b.dataset.case!)));
  document.addEventListener('langchange', () => {
    const active = document.querySelector<HTMLButtonElement>('.mc-btn.btn-primary');
    render(active?.dataset.case || 'int');
  });
  setActive('int');
</script>
