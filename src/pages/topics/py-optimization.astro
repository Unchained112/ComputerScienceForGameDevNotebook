        { label: 'C++ vector<int>', bytes: 4024, color: '#22D3EE', noteZh: '数据 + 24B 头', noteEn: 'data + 24B header' },
        { label: 'Python list[int]', bytes: 36000, color: '#FBBF24', noteZh: '1000×28B对象 + 1000×8B指针 + 56B头', noteEn: '1000×28B objs + 1000×8B ptrs + 56B' },
        { label: 'numpy int32[1000]', bytes: 4096, color: '#A78BFA', noteZh: '连续 C 数组 + 小头，接近 C', noteEn: 'contiguous C array, near C' },
      ],
      noteZh: 'Python list 存 int 比 C 贵 9 倍；numpy 几乎抹平差距。',
