<script>
  // 值类别五分法可视化
  const SVGNS = 'http://www.w3.org/2000/svg';
  const svg = document.getElementById('vc-svg') as unknown as SVGSVGElement;
  const vcBtns = document.querySelectorAll<HTMLButtonElement>('.vc-btn');

  interface CatData {
    titleZh: string; titleEn: string;
    descZh: string; descEn: string;
    examplesZh: string[]; examplesEn: string[];
    color: string;
  }

  const CATS: Record<string, CatData> = {
    overview: {
      titleZh: '值类别五分法', titleEn: 'Five Value Categories',
      descZh: '表达式按"有身份(i)"和"可移动(m)"两个维度分为五类',
      descEn: 'Expressions are classified by "has identity(i)" and "movable(m)" into five categories',
      examplesZh: [], examplesEn: [],
      color: '#22D3EE',
    },
    lvalue: {
      titleZh: 'lvalue（左值）', titleEn: 'lvalue',
      descZh: '有身份、不可移动。通常是具名变量、可取地址的表达式。',
      descEn: 'Has identity, not movable. Typically named variables, addressable expressions.',
      examplesZh: ['int x; → x 是 lvalue', 'arr[i] → 下标表达式', '*p → 解引用', 'std::cout → 流对象'],
      examplesEn: ['int x; → x is lvalue', 'arr[i] → subscript', '*p → dereference', 'std::cout → stream object'],
      color: '#22C55E',
    },
    prvalue: {
      titleZh: 'prvalue（纯右值）', titleEn: 'prvalue',
      descZh: '无身份、可移动。临时对象、字面量、算术表达式。',
      descEn: 'No identity, movable. Temporaries, literals, arithmetic results.',
      examplesZh: ['42 → 整数字面量', 'x + 1 → 算术结果', 'String("hi") → 临时对象', 'true → 布尔字面量'],
      examplesEn: ['42 → integer literal', 'x + 1 → arithmetic result', 'String("hi") → temporary', 'true → bool literal'],
      color: '#FBBF24',
    },
    xvalue: {
      titleZh: 'xvalue（将亡值）', titleEn: 'xvalue',
      descZh: '有身份且可移动。std::move 的结果、返回右值引用的函数调用。',
      descEn: 'Has identity and movable. Result of std::move, function returning rvalue ref.',
      examplesZh: ['std::move(x) → 转为 xvalue', 'std::forward<T>(x) → 条件转换', '返回 T&& 的函数调用', 'std::move(x).member'],
      examplesEn: ['std::move(x) → becomes xvalue', 'std::forward<T>(x) → conditional', 'function returning T&&', 'std::move(x).member'],
      color: '#A78BFA',
    },
  };

  function lang(): 'zh' | 'en' { return document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh'; }

  function render(cat: string) {
    svg.innerHTML = '';
    const data = CATS[cat];
    if (!data) return;

    if (cat === 'overview') {
      // 绘制树形分类图
      const cx = 400, cy = 150;
      // 根节点 expression
      const root = document.createElementNS(SVGNS, 'rect');
      root.setAttribute('x', String(cx - 80)); root.setAttribute('y', '20');
      root.setAttribute('width', '160'); root.setAttribute('height', '40');
      root.setAttribute('rx', '8'); root.setAttribute('fill', '#22D3EE22');
      root.setAttribute('stroke', '#22D3EE'); root.setAttribute('stroke-width', '2');
      svg.appendChild(root);
      const rootT = document.createElementNS(SVGNS, 'text');
      rootT.setAttribute('x', String(cx)); rootT.setAttribute('y', '45');
      rootT.setAttribute('text-anchor', 'middle'); rootT.setAttribute('font-size', '14');
      rootT.setAttribute('font-weight', '700'); rootT.setAttribute('fill', '#22D3EE');
      rootT.textContent = 'expression';
      svg.appendChild(rootT);

      // glvalue / rvalue
      const gl = document.createElementNS(SVGNS, 'rect');
      gl.setAttribute('x', '100'); gl.setAttribute('y', '110');
      gl.setAttribute('width', '180'); gl.setAttribute('height', '40');
      gl.setAttribute('rx', '8'); gl.setAttribute('fill', '#22C55E22');
      gl.setAttribute('stroke', '#22C55E'); gl.setAttribute('stroke-width', '2');
      svg.appendChild(gl);
      const glT = document.createElementNS(SVGNS, 'text');
      glT.setAttribute('x', '190'); glT.setAttribute('y', '135');
      glT.setAttribute('text-anchor', 'middle'); glT.setAttribute('font-size', '13');
      glT.setAttribute('font-weight', '700'); glT.setAttribute('fill', '#22C55E');
      glT.textContent = 'glvalue (has identity)';
      svg.appendChild(glT);

      const rv = document.createElementNS(SVGNS, 'rect');
      rv.setAttribute('x', '520'); rv.setAttribute('y', '110');
      rv.setAttribute('width', '180'); rv.setAttribute('height', '40');
      rv.setAttribute('rx', '8'); rv.setAttribute('fill', '#F8717122');
      rv.setAttribute('stroke', '#F87171'); rv.setAttribute('stroke-width', '2');
      svg.appendChild(rv);
      const rvT = document.createElementNS(SVGNS, 'text');
      rvT.setAttribute('x', '610'); rvT.setAttribute('y', '135');
      rvT.setAttribute('text-anchor', 'middle'); rvT.setAttribute('font-size', '13');
      rvT.setAttribute('font-weight', '700'); rvT.setAttribute('fill', '#F87171');
      rvT.textContent = 'rvalue (movable)';
      svg.appendChild(rvT);

      // 连线
      const l1 = document.createElementNS(SVGNS, 'line');
      l1.setAttribute('x1', String(cx)); l1.setAttribute('y1', '60');
      l1.setAttribute('x2', '190'); l1.setAttribute('y2', '110');
      l1.setAttribute('stroke', 'rgba(148,163,184,0.4)'); l1.setAttribute('stroke-width', '1.5');
      svg.appendChild(l1);
      const l2 = document.createElementNS(SVGNS, 'line');
      l2.setAttribute('x1', String(cx)); l2.setAttribute('y1', '60');
      l2.setAttribute('x2', '610'); l2.setAttribute('y2', '110');
      l2.setAttribute('stroke', 'rgba(148,163,184,0.4)'); l2.setAttribute('stroke-width', '1.5');
      svg.appendChild(l2);

      // 三个叶子
      const leaves = [
        { x: 40, y: 210, w: 130, label: 'lvalue', color: '#22C55E', sub: 'i=✓ m=✗' },
        { x: 335, y: 210, w: 130, label: 'xvalue', color: '#A78BFA', sub: 'i=✓ m=✓' },
        { x: 630, y: 210, w: 130, label: 'prvalue', color: '#FBBF24', sub: 'i=✗ m=✓' },
      ];
      for (const lf of leaves) {
        const r = document.createElementNS(SVGNS, 'rect');
        r.setAttribute('x', String(lf.x)); r.setAttribute('y', String(lf.y));
        r.setAttribute('width', String(lf.w)); r.setAttribute('height', '50');
        r.setAttribute('rx', '8'); r.setAttribute('fill', lf.color + '22');
        r.setAttribute('stroke', lf.color); r.setAttribute('stroke-width', '2');
        svg.appendChild(r);
        const t = document.createElementNS(SVGNS, 'text');
        t.setAttribute('x', String(lf.x + lf.w / 2)); t.setAttribute('y', String(lf.y + 22));
        t.setAttribute('text-anchor', 'middle'); t.setAttribute('font-size', '14');
        t.setAttribute('font-weight', '700'); t.setAttribute('fill', lf.color);
        t.setAttribute('font-family', 'monospace');
        t.textContent = lf.label;
        svg.appendChild(t);
        const s = document.createElementNS(SVGNS, 'text');
        s.setAttribute('x', String(lf.x + lf.w / 2)); s.setAttribute('y', String(lf.y + 40));
        s.setAttribute('text-anchor', 'middle'); s.setAttribute('font-size', '11');
        s.setAttribute('fill', '#94A3B8'); s.setAttribute('font-family', 'monospace');
        s.textContent = lf.sub;
        svg.appendChild(s);
      }

      // 连线到叶子
      const l3 = document.createElementNS(SVGNS, 'line');
      l3.setAttribute('x1', '190'); l3.setAttribute('y1', '150');
      l3.setAttribute('x2', '105'); l3.setAttribute('y2', '210');
      l3.setAttribute('stroke', 'rgba(148,163,184,0.4)'); l3.setAttribute('stroke-width', '1.5');
      svg.appendChild(l3);
      const l4 = document.createElementNS(SVGNS, 'line');
      l4.setAttribute('x1', '280'); l4.setAttribute('y1', '150');
      l4.setAttribute('x2', '400'); l4.setAttribute('y2', '210');
      l4.setAttribute('stroke', 'rgba(148,163,184,0.4)'); l4.setAttribute('stroke-width', '1.5');
      svg.appendChild(l4);
      const l5 = document.createElementNS(SVGNS, 'line');
      l5.setAttribute('x1', '520'); l5.setAttribute('y1', '150');
      l5.setAttribute('x2', '695'); l5.setAttribute('y2', '210');
      l5.setAttribute('stroke', 'rgba(148,163,184,0.4)'); l5.setAttribute('stroke-width', '1.5');
      svg.appendChild(l5);
      const l6 = document.createElementNS(SVGNS, 'line');
      l6.setAttribute('x1', '700'); l6.setAttribute('y1', '150');
      l6.setAttribute('x2', '400'); l6.setAttribute('y2', '210');
      l6.setAttribute('stroke', 'rgba(148,163,184,0.4)'); l6.setAttribute('stroke-width', '1.5');
      svg.appendChild(l6);

      const note = document.createElementNS(SVGNS, 'text');
      note.setAttribute('x', '400'); note.setAttribute('y', '285');
      note.setAttribute('text-anchor', 'middle'); note.setAttribute('font-size', '12');
      note.setAttribute('fill', '#94A3B8');
      note.textContent = lang() === 'en' ? 'i = has identity, m = movable' : 'i = 有身份, m = 可移动';
      svg.appendChild(note);
    } else {
      // 单个类别详情
      const title = document.createElementNS(SVGNS, 'text');
      title.setAttribute('x', '400'); title.setAttribute('y', '40');
      title.setAttribute('text-anchor', 'middle'); title.setAttribute('font-size', '18');
      title.setAttribute('font-weight', '700'); title.setAttribute('fill', data.color);
      title.setAttribute('font-family', 'monospace');
      title.textContent = lang() === 'en' ? data.titleEn : data.titleZh;
      svg.appendChild(title);

      const desc = document.createElementNS(SVGNS, 'text');
      desc.setAttribute('x', '400'); desc.setAttribute('y', '75');
      desc.setAttribute('text-anchor', 'middle'); desc.setAttribute('font-size', '13');
      desc.setAttribute('fill', '#CBD5E1');
      // wrap
      const descText = lang() === 'en' ? data.descEn : data.descZh;
      const words = descText.split('');
      let line = '';
      let dy = 0;
      for (let i = 0; i < words.length; i++) {
        const test = line + words[i];
        if (test.length > 50) {
          const t = document.createElementNS(SVGNS, 'text');
          t.setAttribute('x', '400'); t.setAttribute('y', String(75 + dy));
          t.setAttribute('text-anchor', 'middle'); t.setAttribute('font-size', '13');
          t.setAttribute('fill', '#CBD5E1');
          t.textContent = line;
          svg.appendChild(t);
          line = words[i];
          dy += 20;
        } else {
          line = test;
        }
      }
      if (line) {
        const t = document.createElementNS(SVGNS, 'text');
        t.setAttribute('x', '400'); t.setAttribute('y', String(75 + dy));
        t.setAttribute('text-anchor', 'middle'); t.setAttribute('font-size', '13');
        t.setAttribute('fill', '#CBD5E1');
        t.textContent = line;
        svg.appendChild(t);
      }

      const examples = lang() === 'en' ? data.examplesEn : data.examplesZh;
      const exTitle = document.createElementNS(SVGNS, 'text');
      exTitle.setAttribute('x', '400'); exTitle.setAttribute('y', String(75 + dy + 35));
      exTitle.setAttribute('text-anchor', 'middle'); exTitle.setAttribute('font-size', '14');
      exTitle.setAttribute('font-weight', '600'); exTitle.setAttribute('fill', data.color);
      exTitle.textContent = lang() === 'en' ? 'Examples' : '示例';
      svg.appendChild(exTitle);

      for (let i = 0; i < examples.length; i++) {
        const t = document.createElementNS(SVGNS, 'text');
        t.setAttribute('x', '400'); t.setAttribute('y', String(75 + dy + 65 + i * 24));
        t.setAttribute('text-anchor', 'middle'); t.setAttribute('font-size', '13');
        t.setAttribute('fill', '#CBD5E1'); t.setAttribute('font-family', 'monospace');
        t.textContent = '• ' + examples[i];
        svg.appendChild(t);
      }
    }
  }

  function setActive(cat: string) {
    vcBtns.forEach(b => b.classList.toggle('btn-primary', b.dataset.cat === cat));
    render(cat);
  }
  vcBtns.forEach(b => b.addEventListener('click', () => setActive(b.dataset.cat!)));
  document.addEventListener('langchange', () => {
    const active = document.querySelector<HTMLButtonElement>('.vc-btn.btn-primary');
    render(active?.dataset.cat || 'overview');
  });
  setActive('overview');
</script>
