    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">客户端预测与回滚（伪代码）</span><span slot="en">Client Prediction & Rollback (Pseudocode)</span></Bilingual></h2>
      <CodeTabs
  cpp={`<pre><code>// 客户端预测 + 服务器权威回滚（FPS 标准模型）
#include &lt;deque&gt;

struct PlayerState &#123; float x, y, z; float vx, vy, vz; &#125;;
struct Input &#123; int seq; float dx, dy; bool jump; &#125;;

class ClientPrediction &#123;
    PlayerState current;              // 当前预测状态
    std::deque&lt;Input&gt; pendingInputs; // 已发送未确认的输入
    int serverSeq = 0;                // 服务器已确认的最新序列号

    // 玩家按键 → 立即模拟（不等服务器）
    void onInput(Input input) &#123;
        pendingInputs.push_back(input);
        // 客户端立即应用：零输入延迟感
        current = simulateStep(current, input);
        sendToServer(input);  // UDP 发送
    &#125;

    // 收到服务器权威状态
    void onServerState(PlayerState serverState, int ackSeq) &#123;
        serverSeq = ackSeq;
        // 1. 回滚到服务器状态
        current = serverState;
        // 2. 移除已确认的输入
        while (!pendingInputs.empty() &amp;&amp;
               pendingInputs.front().seq &lt;= ackSeq)
            pendingInputs.pop_front();
        // 3. 重新模拟未确认的输入（replay）
        for (auto&amp; input : pendingInputs)
            current = simulateStep(current, input);
        // 若与预测差异大 → 画面跳变（rubberbanding）
    &#125;

    PlayerState simulateStep(PlayerState s, Input in) &#123;
        s.x += in.dx * 0.1f;  s.z += in.dy * 0.1f;
        if (in.jump) s.vy = 5.0f;
        // ... 物理/碰撞模拟 ...
        return s;
    &#125;
&#125;;</code></pre>`}
  py={`<pre><code># 客户端预测 + 服务器权威回滚（FPS 标准模型）
from dataclasses import dataclass, field
from collections import deque

@dataclass
class PlayerState:
    x: float = 0; y: float = 0; z: float = 0
    vx: float = 0; vy: float = 0; vz: float = 0

@dataclass
class Input:
    seq: int
    dx: float; dy: float
    jump: bool

class ClientPrediction:
    def __init__(self):
        self.current = PlayerState()             # 当前预测状态
        self.pending_inputs = deque()             # 已发送未确认的输入
        self.server_seq = 0                       # 服务器已确认的最新序列号

    def on_input(self, inp: Input):
        """玩家按键 → 立即模拟（不等服务器）"""
        self.pending_inputs.append(inp)
        # 客户端立即应用：零输入延迟感
        self.current = self._simulate(self.current, inp)
        self._send_to_server(inp)  # UDP 发送

    def on_server_state(self, server_state: PlayerState, ack_seq: int):
        """收到服务器权威状态"""
        self.server_seq = ack_seq
        # 1. 回滚到服务器状态
        self.current = PlayerState(**server_state.__dict__)
        # 2. 移除已确认的输入
        while self.pending_inputs and self.pending_inputs[0].seq <= ack_seq:
            self.pending_inputs.popleft()
        # 3. 重新模拟未确认的输入（replay）
        for inp in self.pending_inputs:
            self.current = self._simulate(self.current, inp)
        # 若与预测差异大 → 画面跳变（rubberbanding）

    def _simulate(self, s: PlayerState, inp: Input) -> PlayerState:
        s.x += inp.dx * 0.1
        s.z += inp.dy * 0.1
        if inp.jump:
            s.vy = 5.0
        # ... 物理/碰撞模拟 ...
        return s</code></pre>`}
