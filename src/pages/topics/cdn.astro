    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">游戏联机延迟优化策略</span><span slot="en">Multiplayer Latency Optimization</span></Bilingual></h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="text-ink-muted text-left"><tr class="border-b border-[color:var(--glass-border)]"><th class="py-2 pr-4"><Bilingual><span slot="zh">策略</span><span slot="en">Strategy</span></Bilingual></th><th class="py-2 pr-4"><Bilingual><span slot="zh">层级</span><span slot="en">Layer</span></Bilingual></th><th class="py-2 pr-4"><Bilingual><span slot="zh">效果</span><span slot="en">Effect</span></Bilingual></th><th class="py-2 pr-4"><Bilingual><span slot="zh">适用</span><span slot="en">Game Type</span></Bilingual></th></tr></thead>
          <tbody class="text-ink">
