    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">游戏 Netcode 核心技术</span><span slot="en">Game Netcode Core Techniques</span></Bilingual></h2>
      <div class="space-y-3 text-sm">
        <div class="p-3 rounded-lg border border-[color:var(--glass-border)]">
          <p class="font-semibold text-func-green mb-1">① <Bilingual><span slot="zh">客户端预测（Client-Side Prediction）</span><span slot="en">Client-Side Prediction</span></Bilingual></p>
          <p class="text-ink-muted"><Bilingual><span slot="zh">玩家按键后<b>客户端立即</b>模拟移动结果，不等服务器确认。服务器权威返回<b>纠正</b>时再回滚重放。<b>Quake</b> 首创，现代 FPS 标配。显著降低<b>输入延迟感</b>（从 RTT/2 降到 ~0）。</span><span slot="en">On input, the client <b>immediately</b> simulates movement, without waiting for server. When the server sends <b>correction</b>, the client rolls back and replays. Pioneered by <b>Quake</b>, standard in modern FPS. Reduces <b>input latency</b> from RTT/2 to ~0.</span></Bilingual></p>
        </div>
        <div class="p-3 rounded-lg border border-[color:var(--glass-border)]">
          <p class="font-semibold text-primary-cyan mb-1">② <Bilingual><span slot="zh">服务器插值与外推</span><span slot="en">Server Interpolation & Extrapolation</span></Bilingual></p>
          <p class="text-ink-muted"><Bilingual><span slot="zh">远端玩家位置只在离散时刻收到（每 tick 一个快照）。<b>插值</b>在两个快照间平滑过渡（有 RTT/2 延迟但丝滑）；<b>外推</b>用速度推算未来位置（低延迟但可能穿墙）。通常用<b>插值 + 小外推</b>组合。</span><span slot="en">Remote player positions arrive at discrete snapshots (one per tick). <b>Interpolation</b> smoothly blends between snapshots (RTT/2 delay but smooth); <b>extrapolation</b> predicts future position by velocity (low latency but may clip). Usually combined.</span></Bilingual></p>
        </div>
        <div class="p-3 rounded-lg border border-[color:var(--glass-border)]">
          <p class="font-semibold text-func-amber mb-1">③ <Bilingual><span slot="zh">延迟补偿（Lag Compensation）</span><span slot="en">Lag Compensation</span></Bilingual></p>
          <p class="text-ink-muted"><Bilingual><span slot="zh">服务器维护<b>历史位置快照</b>。玩家开枪时附带<b>客户端看到的时刻</b>，服务器<b>回滚到该时刻</b>进行命中判定。高延迟玩家也能<b>打中自己看到的目标</b>，但可能被低延迟玩家觉得"已躲开却中弹"。CS/Valorant 核心机制。</span><span slot="en">Server maintains <b>historical position snapshots</b>. On shot, client sends <b>what it saw at that moment</b>; server <b>rewinds to that timestamp</b> for hit detection. High-latency players can <b>hit what they see</b>, but low-latency players may feel "I dodged but got hit". CS/Valorant core mechanic.</span></Bilingual></p>
        </div>
        <div class="p-3 rounded-lg border border-[color:var(--glass-border)]">
          <p class="font-semibold text-func-red mb-1">④ <Bilingual><span slot="zh">回滚网络（Rollback Netcode）</span><span slot="en">Rollback Netcode</span></Bilingual></p>
          <p class="text-ink-muted"><Bilingual><span slot="zh">格斗游戏（街霸/GGXX）专用。双方各自模拟本地输入，收到对方输入时<b>回滚到过去</b>重新模拟到当前帧。<b>GGPO</b> 框架是标杆。优点：零输入延迟；缺点：大量回滚时画面闪烁，对性能要求高。</span><span slot="en">Fighting games (SF/GGXX) specific. Both sides simulate local inputs, then <b>rollback to the past</b> and re-simulate to the present when opponent inputs arrive. <b>GGPO</b> framework is the gold standard. Pro: zero input delay; Con: visual flicker on heavy rollback, high performance demand.</span></Bilingual></p>
        </div>
      </div>
    </section>

    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">CDN 缓存策略代码</span><span slot="en">CDN Cache Strategy Code</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh">游戏资源分发的最佳实践：版本清单文件不缓存，资源文件用内容哈希命名并永久缓存。</span><span slot="en">Best practice for game asset delivery: version manifest is not cached, assets use content-hash names and are permanently cached.</span></Bilingual></p>
      <CodeTabs
  cpp={`<pre><code>// 游戏更新检查 + CDN 下载流程
#include &lt;httplib.h&gt;
#include &lt;nlohmann/json.hpp&gt;

struct AssetManifest &#123;
    std::string version;
    std::vector&lt;struct &#123; std::string name, url, hash; int size; &#125;&gt; assets;
&#125;;

void checkAndUpdate() &#123;
    httplib::Client cdn("https://cdn.game.com");

    // 1. 下载版本清单（不缓存 → 每次拿最新）
    auto res = cdn.Get("/manifest.json");
    auto manifest = nlohmann::json::parse(res-&gt;body);

    // 2. 比对本地版本号
    std::string localVer = readLocalVersion();
    if (manifest["version"] == localVer) return;  // 已是最新

    // 3. 逐个下载变更的资源（URL 含内容哈希 → 永久缓存安全）
    for (auto& asset : manifest["assets"]) &#123;
        std::string url = asset["url"];  // /textures/tex_v3_a1b2c3d4.ktx
        // CDN 边缘命中 → 10ms 内返回（99%+ 命中率）
        auto data = cdn.Get(url.c_str());
        saveAsset(asset["name"], data-&gt;body);

        // 验证 SHA-256（防篡改）
        if (sha256(data-&gt;body) != asset["hash"]) &#123;
            throw std::runtime_error("Asset integrity check failed!");
        &#125;
    &#125;
&#125;</code></pre>`}
  py={`<pre><code># 游戏更新检查 + CDN 下载流程
import requests
import hashlib

CDN_BASE = "https://cdn.game.com"

def check_and_update():
    # 1. 下载版本清单（Cache-Control: no-cache → 每次拿最新）
    resp = requests.get(f"{CDN_BASE}/manifest.json",
                        headers={"Cache-Control": "no-cache"})
    manifest = resp.json()

    # 2. 比对本地版本号
    local_ver = read_local_version()
    if manifest["version"] == local_ver:
        return  # 已是最新

    # 3. 逐个下载变更的资源（URL 含内容哈希 → 永久缓存安全）
    for asset in manifest["assets"]:
        url = asset["url"]  # /textures/tex_v3_a1b2c3d4.ktx
        # CDN 边缘命中 → 10ms 内返回（99%+ 命中率）
        data = requests.get(f"{CDN_BASE}{url}").content

        # 验证 SHA-256（防篡改）
        if hashlib.sha256(data).hexdigest() != asset["hash"]:
            raise ValueError("Asset integrity check failed!")

        save_asset(asset["name"], data)

# CDN 缓存策略最佳实践：
# - manifest.json: Cache-Control: no-cache, max-age=0
# - *.ktx/textures: Cache-Control: public, max-age=31536000, immutable
# - *.js/scripts:  Cache-Control: public, max-age=31536000, immutable
# （文件名含内容哈希，内容变更→哈希变更→URL变更→自动失效）</code></pre>`}
