            <tr><td class="py-2 pr-4 text-ink-muted"><Bilingual><span slot="zh">游戏适用</span><span slot="en">Game Use</span></Bilingual></td><td class="py-2 pr-4 text-ink-muted"><Bilingual><span slot="zh">小规模内测</span><span slot="en">Small beta</span></Bilingual></td><td class="py-2 pr-4 text-func-green"><Bilingual><span slot="zh">主流方案</span><span slot="en">Mainstream</span></Bilingual></td><td class="py-2 pr-4 text-func-amber"><Bilingual><span slot="zh">大文件分发（补丁）</span><span slot="en">Large patches</span></Bilingual></td></tr>
