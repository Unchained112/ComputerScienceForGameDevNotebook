<script>
  // 智能指针所有权链可视化
  const SVGNS = 'http://www.w3.org/2000/svg';
  const svg = document.getElementById('sp-svg') as unknown as SVGSVGElement;
  const spBtns = document.querySelectorAll<HTMLButtonElement>('.sp-btn');

  interface Node2 { x: number; y: number; label: string; color: string; }
  interface Edge { from: number; to: number; label: string; style: 'strong' | 'weak'; color: string; }
  interface SPData {
    titleZh: string; titleEn: string;
    nodes: Node2[];
    edges: Edge[];
    noteZh: string; noteEn: string;
    noteColor: string;
  }

  const DATA: Record<string, SPData> = {
    unique: {
      titleZh: 'unique_ptr：独占所有权', titleEn: 'unique_ptr: Exclusive Ownership',
      nodes: [
        { x: 150, y: 120, label: 'Owner', color: '#22C55E' },
        { x: 500, y: 120, label: 'Texture', color: '#22D3EE' },
      ],
      edges: [
        { from: 0, to: 1, label: 'unique_ptr (owns)', style: 'strong', color: '#22C55E' },
      ],
      noteZh: '唯一所有者，析构时自动 delete。不可拷贝，只能 std::move 转移。',
      noteEn: 'Sole owner, auto-deletes on destruction. Non-copyable, move-only.',
      noteColor: '#22C55E',
    },
    shared: {
      titleZh: 'shared_ptr：共享所有权', titleEn: 'shared_ptr: Shared Ownership',
      nodes: [
        { x: 100, y: 80, label: 'Owner A', color: '#FBBF24' },
        { x: 100, y: 180, label: 'Owner B', color: '#FBBF24' },
        { x: 500, y: 130, label: 'Texture\nrefcount: 2', color: '#22D3EE' },
      ],
      edges: [
        { from: 0, to: 2, label: 'shared_ptr', style: 'strong', color: '#FBBF24' },
        { from: 1, to: 2, label: 'shared_ptr', style: 'strong', color: '#FBBF24' },
      ],
      noteZh: '引用计数 = 2。A 和 B 都析构后，Texture 才释放。',
      noteEn: 'refcount = 2. Texture freed only after both A and B destruct.',
      noteColor: '#FBBF24',
    },
    weak: {
      titleZh: 'weak_ptr 打破循环引用', titleEn: 'weak_ptr Breaks Cycle',
      nodes: [
        { x: 150, y: 80, label: 'Node A', color: '#22C55E' },
        { x: 500, y: 80, label: 'Node B', color: '#22C55E' },
        { x: 325, y: 200, label: 'Leak!', color: '#F87171' },
      ],
      edges: [
        { from: 0, to: 1, label: 'shared_ptr (strong)', style: 'strong', color: '#22C55E' },
        { from: 1, to: 0, label: 'weak_ptr (observe)', style: 'weak', color: '#A78BFA' },
      ],
      noteZh: 'B 用 weak_ptr 观察 A（不增计数）。A 可正常释放 → 打破环。',
      noteEn: 'B observes A via weak_ptr (no refcount). A frees normally → cycle broken.',
      noteColor: '#A78BFA',
    },
  };

  function lang(): 'zh' | 'en' { return document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh'; }

  function render(type: string) {
    const data = DATA[type];
    if (!data) return;
    svg.innerHTML = '';

    // 标题
    const title = document.createElementNS(SVGNS, 'text');
    title.setAttribute('x', '400'); title.setAttribute('y', '30');
    title.setAttribute('text-anchor', 'middle'); title.setAttribute('font-size', '16');
    title.setAttribute('font-weight', '700'); title.setAttribute('fill', '#22D3EE');
    title.textContent = lang() === 'en' ? data.titleEn : data.titleZh;
    svg.appendChild(title);

    // 边
    for (const e of data.edges) {
      const from = data.nodes[e.from], to = data.nodes[e.to];
      const line = document.createElementNS(SVGNS, 'line');
      line.setAttribute('x1', String(from.x + 60)); line.setAttribute('y1', String(from.y));
      line.setAttribute('x2', String(to.x - 60)); line.setAttribute('y2', String(to.y));
      line.setAttribute('stroke', e.color);
      line.setAttribute('stroke-width', e.style === 'strong' ? '3' : '2');
      if (e.style === 'weak') line.setAttribute('stroke-dasharray', '6 4');
      line.setAttribute('marker-end', 'url(#sp-arrow)');
      svg.appendChild(line);

      // 标签
      const mx = (from.x + to.x) / 2, my = (from.y + to.y) / 2 - 8;
      const t = document.createElementNS(SVGNS, 'text');
      t.setAttribute('x', String(mx)); t.setAttribute('y', String(my));
      t.setAttribute('text-anchor', 'middle'); t.setAttribute('font-size', '11');
      t.setAttribute('fill', e.color); t.setAttribute('font-weight', '600');
      t.textContent = e.label;
      svg.appendChild(t);
    }

    // 节点
    for (const n of data.nodes) {
      const rect = document.createElementNS(SVGNS, 'rect');
      rect.setAttribute('x', String(n.x - 60)); rect.setAttribute('y', String(n.y - 25));
      rect.setAttribute('width', '120'); rect.setAttribute('height', '50');
      rect.setAttribute('rx', '8'); rect.setAttribute('fill', n.color + '22');
      rect.setAttribute('stroke', n.color); rect.setAttribute('stroke-width', '2');
      svg.appendChild(rect);

      const lines = n.label.split('\n');
      for (let i = 0; i < lines.length; i++) {
        const t = document.createElementNS(SVGNS, 'text');
        t.setAttribute('x', String(n.x)); t.setAttribute('y', String(n.y + 5 + (i - (lines.length-1)/2) * 14));
        t.setAttribute('text-anchor', 'middle'); t.setAttribute('font-size', '12');
        t.setAttribute('font-weight', '600'); t.setAttribute('fill', n.color);
        t.setAttribute('font-family', 'monospace');
        t.textContent = lines[i];
        svg.appendChild(t);
      }
    }

    // 注释
    const note = document.createElementNS(SVGNS, 'text');
    note.setAttribute('x', '400'); note.setAttribute('y', '265');
    note.setAttribute('text-anchor', 'middle'); note.setAttribute('font-size', '12');
    note.setAttribute('fill', data.noteColor);
    note.textContent = lang() === 'en' ? data.noteEn : data.noteZh;
    svg.appendChild(note);

    // arrow marker
    const defs = document.createElementNS(SVGNS, 'defs');
    const marker = document.createElementNS(SVGNS, 'marker');
    marker.setAttribute('id', 'sp-arrow');
    marker.setAttribute('viewBox', '0 0 10 10');
    marker.setAttribute('refX', '8'); marker.setAttribute('refY', '5');
    marker.setAttribute('markerWidth', '6'); marker.setAttribute('markerHeight', '6');
    marker.setAttribute('orient', 'auto');
    const path = document.createElementNS(SVGNS, 'path');
    path.setAttribute('d', 'M 0 0 L 10 5 L 0 10 z');
    path.setAttribute('fill', 'context-stroke');
    marker.appendChild(path);
    defs.appendChild(marker);
    svg.appendChild(defs);
  }

  function setActive(type: string) {
    spBtns.forEach(b => b.classList.toggle('btn-primary', b.dataset.type === type));
    render(type);
  }
  spBtns.forEach(b => b.addEventListener('click', () => setActive(b.dataset.type!)));
  document.addEventListener('langchange', () => {
    const active = document.querySelector<HTMLButtonElement>('.sp-btn.btn-primary');
    render(active?.dataset.type || 'unique');
  });
  setActive('unique');
</script>
