---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Bilingual from '../../components/Bilingual.astro';
import CodeTabs from '../../components/CodeTabs.astro';
---
<BaseLayout title="RAII & Smart Pointers · CS Notebook">
  <article class="space-y-6">
    <header>
      <p class="text-sm uppercase tracking-[0.2em] text-primary-cyan mb-2">Languages / C++ RAII</p>
      <h1 class="text-3xl font-bold mb-2">
        <Bilingual><span slot="zh">RAII 与智能指针</span><span slot="en">RAII & Smart Pointers</span></Bilingual>
      </h1>
      <p class="text-ink-muted leading-relaxed">
        <Bilingual>
          <span slot="zh"><b>RAII</b>（Resource Acquisition Is Initialization）是 C++ 区别于其他语言的灵魂——将资源（内存、文件、锁、GPU 句柄）的<b>获取绑定到构造函数</b>，<b>释放绑定到析构函数</b>。无论函数如何退出（正常返回、异常、提前 return），析构函数保证执行，资源不会泄漏。<b>智能指针</b>是 RAII 应用于内存的产物：<code>unique_ptr</code> 独占、<code>shared_ptr</code> 共享、<code>weak_ptr</code> 打破循环引用。点击下方查看所有权链可视化。</span>
          <span slot="en"><b>RAII</b> (Resource Acquisition Is Initialization) is C++'s defining feature — binding resource acquisition (memory, files, locks, GPU handles) to <b>constructors</b> and release to <b>destructors</b>. No matter how a function exits (normal return, exception, early return), destructors are guaranteed to run — no leaks. <b>Smart pointers</b> apply RAII to memory: <code>unique_ptr</code> for exclusive ownership, <code>shared_ptr</code> for shared, <code>weak_ptr</code> to break cycles. Click below to visualize ownership chains.</span>
        </Bilingual>
      </p>
    </header>

    <!-- 交互：智能指针所有权链 -->
    <div class="glass p-5" data-viz="smartptr-ownership">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <button class="btn sp-btn btn-primary" data-type="unique">
          <span data-lang="zh">unique_ptr</span><span data-lang="en">unique_ptr</span>
        </button>
        <button class="btn sp-btn" data-type="shared">
          <span data-lang="zh">shared_ptr</span><span data-lang="en">shared_ptr</span>
        </button>
        <button class="btn sp-btn" data-type="weak">
          <span data-lang="zh">weak_ptr 打环</span><span data-lang="en">weak_ptr cycle</span>
        </button>
      </div>
      <svg id="sp-svg" viewBox="0 0 800 280" class="w-full h-72 viz-stage"></svg>
    </div>

    <!-- RAII 原理 -->
    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">RAII：资源 = 对象生命周期</span><span slot="en">RAII: Resource = Object Lifetime</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh">RAII 的核心洞察：<b>栈对象的析构是确定性的</b>——编译器保证在作用域结束时调用析构，即使抛出异常也会栈展开（stack unwinding）。将资源获取放进构造函数、释放放进析构函数，资源管理就变成了<b>自动的、异常安全的</b>。对比 Java/Python 的 GC：GC 不确定何时运行，无法管理非内存资源（文件、锁、GPU 句柄）。</span><span slot="en">RAII's core insight: <b>stack object destruction is deterministic</b> — the compiler guarantees destructor calls at scope exit, even during exception stack unwinding. By putting acquisition in constructors and release in destructors, resource management becomes <b>automatic and exception-safe</b>. Contrast with Java/Python GC: GC timing is non-deterministic and cannot manage non-memory resources (files, locks, GPU handles).</span></Bilingual></p>
      <CodeTabs
  cpp={`<pre><code>// ===== 裸指针：手动管理，容易泄漏 =====
void risky() &#123;
    Texture* tex = new Texture("hero.png");  // 手动分配
    render(tex);
    if (error) return;     // ← 忘记 delete！内存泄漏
    delete tex;            // 仅正常路径释放
&#125;

// ===== RAII：自动管理，异常安全 =====
class TextureHolder &#123;
    Texture* tex;
public:
    explicit TextureHolder(const char* path) : tex(new Texture(path)) &#123;&#125;
    ~TextureHolder() &#123; delete tex; &#125;     // 析构自动释放！
    Texture* get() &#123; return tex; &#125;
    // 禁止拷贝（避免 double free）
    TextureHolder(const TextureHolder&amp;) = delete;
    TextureHolder&amp; operator=(const TextureHolder&amp;) = delete;
&#125;;

void safe() &#123;
    TextureHolder tex("hero.png");   // 栈对象
    render(tex.get());
    if (error) return;     // ← 析构仍会调用！无泄漏
    throw std::runtime_error("oops");  // ← 异常也安全！
&#125;  // tex 析构自动 delete

// ===== 通用 RAII：锁、文件、GPU 句柄 =====
std::mutex m;
void threadSafe() &#123;
    std::lock_guard&lt;std::mutex&gt; lock(m);  // 构造时加锁
    // ... 临界区 ...
&#125;  // 析构自动解锁，即使异常

void fileSafe() &#123;
    std::ifstream file("save.dat");   // 构造时打开
    // ... 读写 ...
&#125;  // 析构自动关闭文件

// 游戏引擎：GPU 资源 RAII
class GPUBuffer &#123;
    GLuint id;
public:
    GPUBuffer() &#123; glGenBuffers(1, &amp;id); &#125;     // 构造时分配 GPU 内存
    ~GPUBuffer() &#123; glDeleteBuffers(1, &amp;id); &#125;  // 析构时释放
    void bind() &#123; glBindBuffer(GL_ARRAY_BUFFER, id); &#125;
&#125;;

// C++ RAII vs Java try-with-resources / Python with：
// C++:  编译器强制，所有栈对象自动析构
// Java: 需显式 try-with-resources，仅 AutoCloseable
// Python: 需显式 with 语句，仅 context manager</code></pre>`}
  py={`<pre><code># Python 无 RAII——用 with 语句模拟（需手动使用）

# 裸资源：容易泄漏
def risky():
    f = open("save.dat")
    data = f.read()
    if error:
        return      # ← 忘记 f.close()！文件泄漏
    f.close()

# with 语句：等价 RAII（但需手动写 with）
def safe():
    with open("save.dat") as f:   # __enter__
        data = f.read()
        if error:
            return   # ← __exit__ 自动调用！无泄漏
    # with 退出时自动 close

# 自定义 context manager
class GPUBuffer:
    def __enter__(self):
        self.id = glGenBuffers()
        return self

    def __exit__(self, *exc):
        glDeleteBuffers(self.id)  # 自动释放

    def bind(self):
        glBindBuffer(self.id)

def render():
    with GPUBuffer() as buf:      # 必须手动 with
        buf.bind()
        # ... 渲染 ...
    # __exit__ 自动释放

# C++ RAII vs Python with:
# C++: 栈对象自动析构，无需 with
# Python: 必须显式 with，否则不会 __exit__
# Python 还依赖 GC 回收内存（不确定时机）</code></pre>`}
      />
    </section>

    <!-- unique_ptr -->
    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">unique_ptr：独占所有权</span><span slot="en">unique_ptr: Exclusive Ownership</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh"><code>unique_ptr</code> 是<b>零开销抽象</b>——与裸指针大小相同、性能相同，但自动管理生命周期。同一时刻只有一个 <code>unique_ptr</code> 拥有对象，不可拷贝、只能 <code>std::move</code> 转移所有权。这是 C++ 中<b>默认的堆分配方式</b>——优先用 <code>make_unique</code> 创建（异常安全、避免裸 new）。</span><span slot="en"><code>unique_ptr</code> is <b>zero-overhead</b> — same size and performance as a raw pointer, but with automatic lifetime management. Only one <code>unique_ptr</code> owns the object at a time; it's non-copyable, only <code>std::move</code>-able. This is the <b>default heap allocation method</b> in C++ — prefer <code>make_unique</code> (exception-safe, avoids raw new).</span></Bilingual></p>
      <CodeTabs
  cpp={`<pre><code>#include &lt;memory&gt;

// 创建：make_unique 优于 new（异常安全）
auto tex = std::make_unique&lt;Texture&gt;("hero.png");
// std::unique_ptr<Texture> tex(new Texture("hero.png"));  // 也可以，但不够安全

// 使用：像裸指针一样
tex-&gt;bind();
render(tex.get());   // .get() 获取裸指针（不转移所有权）

// 转移所有权（move）
std::unique_ptr&lt;Texture&gt; tex2 = std::move(tex);  // tex 变 nullptr
// std::unique_ptr<Texture> tex3 = tex;  // 编译错误：不可拷贝

// 函数传参：按值接收 = 转移所有权
void loadToGPU(std::unique_ptr&lt;Texture&gt; tex) &#123;
    tex-&gt;bind();
&#125;  // tex 在此析构，自动 delete
loadToGPU(std::move(tex2));  // 调用方显式转移

// 返回所有权
std::unique_ptr&lt;Texture&gt; createTexture() &#123;
    return std::make_unique&lt;Texture&gt;("hero.png");  // RVO 优化
&#125;
auto myTex = createTexture();  // 所有权从函数转移到调用方

// 自定义删除器（管理非 new 资源）
auto file = std::unique_ptr&lt;FILE, decltype(&amp;fclose)&gt;(
    fopen("save.dat", "rb"), &amp;fclose);
// 析构时调用 fclose 而非 delete

// 数组版本
auto arr = std::make_unique&lt;int[]&gt;(100);  // 100 个 int
arr[0] = 42;

// make_unique 异常安全的原因：
// func(std::make_unique<A>(), std::make_unique<B>());  // 安全
// func(std::unique_ptr<A>(new A()), std::unique_ptr<B>(new B()));  // 可能泄漏！
// 若 new B() 抛异常且 new A() 已执行，A 泄漏（C++17 前不保证求值顺序）</code></pre>`}
  py={`<pre><code># Python 无 unique_ptr 概念——GC 管理一切
# 但可用 contextlib 模拟所有权转移

import contextlib

class Texture:
    def __init__(self, path):
        self.path = path
        print(f"Loaded {path}")

    def __del__(self):
        print(f"Freed {self.path}")  # GC 回收时调用（不确定时机）

# Python 无所有权概念——多个变量可引用同一对象
tex = Texture("hero.png")
tex2 = tex      # 不是转移，而是共享引用
del tex         # 只删除引用，对象不释放（tex2 仍引用）
# 对象在 tex2 也被 del 后才回收（不确定何时）

# 模拟 "move" 语义
def move_tex(tex):
    """接收并接管 tex 的所有权"""
    # Python 无法阻止调用方继续使用 tex
    # 只能靠约定（文档说明）
    tex.bind()
    # 函数结束后 tex 引用消失，GC 决定何时回收

# C++ unique_ptr vs Python:
# C++: 编译期强制单一所有权，零开销
# Python: 运行时 GC，多个引用共享，有开销</code></pre>`}
      />
    </section>

    <!-- shared_ptr & weak_ptr -->
    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">shared_ptr 与 weak_ptr：共享与打破环</span><span slot="en">shared_ptr & weak_ptr: Sharing & Breaking Cycles</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh"><code>shared_ptr</code> 用<b>引用计数</b>实现共享所有权——最后一个引用销毁时释放对象。但引用计数有代价：原子操作（线程安全）、控制块堆分配、比 <code>unique_ptr</code> 慢 2-3 倍。<b>循环引用</b>是 <code>shared_ptr</code> 的致命陷阱——两个对象互相引用，引用计数永不归零，内存泄漏。<code>weak_ptr</code> 是"观察者"——不增加引用计数，用于打破环、缓存、观察生命周期。</span><span slot="en"><code>shared_ptr</code> uses <b>reference counting</b> for shared ownership — the object is freed when the last reference dies. But ref-counting has costs: atomic operations (thread-safe), control block heap alloc, 2-3× slower than <code>unique_ptr</code>. <b>Cyclic references</b> are <code>shared_ptr</code>'s fatal trap — two objects reference each other, ref-count never hits zero, memory leaks. <code>weak_ptr</code> is an "observer" — doesn't increment ref-count, used to break cycles, cache, observe lifetime.</span></Bilingual></p>
      <CodeTabs
  cpp={`<pre><code>#include &lt;memory&gt;

// ===== shared_ptr: 共享所有权 =====
auto tex = std::make_shared&lt;Texture&gt;("hero.png");  // 引用计数 = 1
&#123;
    auto tex2 = tex;   // 拷贝：引用计数 = 2
    render(tex2);
&#125;  // tex2 析构：引用计数 = 1，对象未释放
// tex 析构：引用计数 = 0，对象 delete

// make_shared vs new：
// make_shared: 一次分配（对象 + 控制块），缓存友好
// shared_ptr<T>(new T): 两次分配（对象 + 控制块）
auto p1 = std::make_shared<T>();   // 推荐
auto p2 = std::shared_ptr<T>(new T); // 不推荐

// ===== 循环引用陷阱 =====
struct Node &#123;
    std::shared_ptr&lt;Node&gt; next;   // 强引用
    ~Node() &#123; std::cout &lt;&lt; "~Node\\n"; &#125;
&#125;;

auto a = std::make_shared&lt;Node&gt;();  // a 计数 = 1
auto b = std::make_shared&lt;Node&gt;();  // b 计数 = 1
a-&gt;next = b;   // b 计数 = 2
b-&gt;next = a;   // a 计数 = 2  ← 循环！
// a, b 离开作用域：a 计数 = 1, b 计数 = 1
// 永远不归零！内存泄漏！

// ===== weak_ptr 打破环 =====
struct Node2 &#123;
    std::shared_ptr&lt;Node2&gt; next;        // 强引用（持有）
    std::weak_ptr&lt;Node2&gt; prev;          // 弱引用（观察）
    ~Node2() &#123; std::cout &lt;&lt; "~Node2\\n"; &#125;
&#125;;

auto a2 = std::make_shared&lt;Node2&gt;();
auto b2 = std::make_shared&lt;Node2&gt;();
a2-&gt;next = b2;    // b2 计数 = 2
b2-&gt;prev = a2;    // a2 计数仍 = 1（weak_ptr 不增加计数！）
// a2 离开作用域：计数 = 0，a2 释放
// a2 释放 → a2->next 析构 → b2 计数 = 1
// b2 离开作用域：计数 = 0，b2 释放  ✓ 无泄漏

// 使用 weak_ptr（需 lock 提升为 shared_ptr）
void useNode(std::weak_ptr&lt;Node2&gt; weak) &#123;
    if (auto sp = weak.lock()) &#123;   // 提升为 shared_ptr
        sp-&gt;doSomething();           // 对象仍存活
    &#125; else &#123;
        // 对象已被释放
    &#125;
&#125;

// 游戏场景：资源缓存
class TextureCache &#123;
    std::unordered_map&lt;std::string, std::weak_ptr&lt;Texture&gt;&gt; cache;
public:
    std::shared_ptr&lt;Texture&gt; load(const std::string&amp; path) &#123;
        auto it = cache.find(path);
        if (it != cache.end()) &#123;
            if (auto sp = it-&gt;second.lock()) &#123;
                return sp;  // 缓存命中
            &#125;
        &#125;
        auto sp = std::make_shared&lt;Texture&gt;(path);
        cache[path] = sp;  // weak_ptr 不阻止释放
        return sp;
    &#125;
&#125;;

// 选型决策：
// 独占所有权？        → unique_ptr（默认选择）
// 共享所有权？        → shared_ptr（慎用，有开销）
// 需要观察但不持有？  → weak_ptr
// 编译期已知大小？    → 栈对象（最优）</code></pre>`}
  py={`<pre><code># Python 全部是 "shared_ptr" —— 引用计数 + 循环检测
import sys, weakref

# 引用计数
a = Texture("hero.png")
print(sys.getrefcount(a))  # 2（a + getrefcount 参数）

b = a   # 引用计数 +1
del a   # 引用计数 -1，对象不释放（b 仍引用）
del b   # 引用计数 = 0，对象回收

# 循环引用：Python 有 GC 循环检测器（但不确定何时运行）
class Node:
    def __init__(self):
        self.next = None

a = Node(); b = Node()
a.next = b; b.next = a  # 循环引用
del a; del b  # 引用计数不为 0，但 GC 会检测并回收

# weakref：类似 C++ weak_ptr
import weakref

class Texture:
    pass

tex = Texture()
weak = weakref.ref(tex)
print(weak())   # <Texture object>（对象存活）
del tex
print(weak())   # None（对象已回收）

# 缓存场景
cache = {}
def load_texture(path):
    weak = cache.get(path)
    if weak and weak():
        return weak()  # 缓存命中
    tex = Texture(path)
    cache[path] = weakref.ref(tex)
    return tex

# C++ shared_ptr vs Python 引用计数：
# C++: 原子操作线程安全，无循环检测（需 weak_ptr）
# Python: 非线程安全（GIL 保护），有循环检测 GC</code></pre>`}
      />
      <p class="text-xs text-ink-muted mt-3"><Bilingual><span slot="zh">关联阅读：<a class="text-primary-cyan underline" href="/topics/cpp-move">移动语义</a>讲解所有权转移的底层机制；<a class="text-primary-cyan underline" href="/topics/cpp-memory">内存与指针</a>讲解栈堆分配。</span><span slot="en">Related: <a class="text-primary-cyan underline" href="/topics/cpp-move">Move Semantics</a> for ownership transfer internals; <a class="text-primary-cyan underline" href="/topics/cpp-memory">Memory & Pointers</a> for stack/heap allocation.</span></Bilingual></p>
    </section>
  </article>
