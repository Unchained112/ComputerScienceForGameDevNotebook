        { zh: 'switch(opcode) ~200 条指令', en: 'switch(opcode) ~200 ops' },
        { zh: 'LOAD_* 压栈, BINARY_* 弹栈计算', en: 'LOAD_* push, BINARY_* pop+compute' },
        { zh: '每条指令 Py_INCREF/DECREF', en: 'Py_INCREF/DECREF per op' },
        { zh: 'GIL 在此循环边界检查释放', en: 'GIL released at loop boundaries' },
      ],
    },
  };

  const order = ['src', 'ast', 'code', 'frame', 'eval'];
  const xs = [70, 220, 370, 520, 670];

  function lang(): 'zh' | 'en' { return document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh'; }

  function render(active: string) {
    svg.innerHTML = '';
    const data = STAGES[active];
    if (!data) return;

    // 流水线主轴
    const axis = document.createElementNS(SVGNS, 'line');
    axis.setAttribute('x1', '70'); axis.setAttribute('y1', '60');
    axis.setAttribute('x2', '670'); axis.setAttribute('y2', '60');
    axis.setAttribute('stroke', 'rgba(148,163,184,0.25)'); axis.setAttribute('stroke-width', '2');
    svg.appendChild(axis);

    // 箭头
    for (let i = 0; i < order.length - 1; i++) {
      const arrow = document.createElementNS(SVGNS, 'polygon');
      const ax = (xs[i] + xs[i+1]) / 2;
      arrow.setAttribute('points', `${ax-5},55 ${ax+5},60 ${ax-5},65`);
      arrow.setAttribute('fill', 'rgba(148,163,184,0.4)');
      svg.appendChild(arrow);
    }

    // 各阶段节点
    for (let i = 0; i < order.length; i++) {
      const k = order[i], d = STAGES[k], x = xs[i];
      const isActive = k === active;
      const c = document.createElementNS(SVGNS, 'circle');
      c.setAttribute('cx', String(x)); c.setAttribute('cy', '60');
      c.setAttribute('r', isActive ? '11' : '6');
      c.setAttribute('fill', isActive ? d.color : 'rgba(148,163,184,0.3)');
      c.setAttribute('stroke', d.color); c.setAttribute('stroke-width', '2');
      svg.appendChild(c);

      const label = document.createElementNS(SVGNS, 'text');
      label.setAttribute('x', String(x)); label.setAttribute('y', '88');
      label.setAttribute('text-anchor', 'middle'); label.setAttribute('font-size', '11');
      label.setAttribute('font-weight', isActive ? '700' : '500');
      label.setAttribute('fill', isActive ? d.color : '#64748B');
      label.textContent = lang() === 'en' ? d.nameEn : d.nameZh;
      svg.appendChild(label);
    }

    // 详情卡片
    const cx = 40, cy = 115, cw = 720, ch = 170;
    const card = document.createElementNS(SVGNS, 'rect');
    card.setAttribute('x', String(cx)); card.setAttribute('y', String(cy));
    card.setAttribute('width', String(cw)); card.setAttribute('height', String(ch));
    card.setAttribute('rx', '10'); card.setAttribute('fill', data.color + '11');
    card.setAttribute('stroke', data.color + '55'); card.setAttribute('stroke-width', '1.5');
    svg.appendChild(card);

    const title = document.createElementNS(SVGNS, 'text');
    title.setAttribute('x', String(cx + 20)); title.setAttribute('y', String(cy + 28));
    title.setAttribute('font-size', '15'); title.setAttribute('font-weight', '700');
    title.setAttribute('fill', data.color);
    title.textContent = lang() === 'en' ? data.nameEn : data.nameZh;
    svg.appendChild(title);

    const desc = document.createElementNS(SVGNS, 'text');
    desc.setAttribute('x', String(cx + 20)); desc.setAttribute('y', String(cy + 50));
    desc.setAttribute('font-size', '12'); desc.setAttribute('fill', '#94A3B8');
    desc.textContent = lang() === 'en' ? data.descEn : data.descZh;
    svg.appendChild(desc);

    for (let i = 0; i < data.items.length; i++) {
      const it = data.items[i];
      const col = i % 2;
      const row = Math.floor(i / 2);
      const ix = cx + 20 + col * 360;
      const iy = cy + 80 + row * 26;
      const bullet = document.createElementNS(SVGNS, 'circle');
      bullet.setAttribute('cx', String(ix)); bullet.setAttribute('cy', String(iy - 4));
      bullet.setAttribute('r', '2.5'); bullet.setAttribute('fill', data.color);
      svg.appendChild(bullet);
      const t = document.createElementNS(SVGNS, 'text');
      t.setAttribute('x', String(ix + 10)); t.setAttribute('y', String(iy));
      t.setAttribute('font-size', '12'); t.setAttribute('fill', '#CBD5E1');
      t.textContent = lang() === 'en' ? it.en : it.zh;
      svg.appendChild(t);
    }
  }

  function setActive(stage: string) {
    plBtns.forEach(b => b.classList.toggle('btn-primary', b.dataset.stage === stage));
    render(stage);
  }
  plBtns.forEach(b => b.addEventListener('click', () => setActive(b.dataset.stage!)));
  document.addEventListener('langchange', () => {
    const active = document.querySelector<HTMLButtonElement>('.pl-btn.btn-primary');
    render(active?.dataset.stage || 'src');
  });
  setActive('src');
</script>
