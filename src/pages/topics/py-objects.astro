<script>
  // PyObject 内存布局可视化
  const SVGNS = 'http://www.w3.org/2000/svg';
  const svg = document.getElementById('obj-svg') as unknown as SVGSVGElement;
  const objBtns = document.querySelectorAll<HTMLButtonElement>('.obj-btn');

  interface Field { name: string; size: string; color: string; zh: string; en: string; }
  interface ObjData {
    titleZh: string; titleEn: string; total: string;
    fields: Field[];
    noteZh: string; noteEn: string;
  }

  const OBJS: Record<string, ObjData> = {
    int: {
      titleZh: 'int 对象 (PyLongObject)', titleEn: 'int object (PyLongObject)', total: '28 字节',
      fields: [
        { name: 'ob_refcnt', size: '8B', color: '#FBBF24', zh: '引用计数', en: 'refcount' },
        { name: 'ob_type', size: '8B', color: '#A78BFA', zh: '→ int 类型', en: '→ int type' },
        { name: 'ob_size', size: '8B', color: '#22D3EE', zh: '位数(变长头)', en: 'digit count' },
        { name: 'ob_digit[0]', size: '4B', color: '#22C55E', zh: '数值(30位/槽)', en: 'value (30-bit)' },
      ],
      noteZh: 'C 的 int 仅 4 字节；Python int 28 字节（7 倍），且支持任意精度。',
      noteEn: 'C int is 4 bytes; Python int is 28 bytes (7x), but supports arbitrary precision.',
    },
    list: {
      titleZh: 'list 对象 (PyListObject)', titleEn: 'list object (PyListObject)', total: '56 + 8N 字节',
      fields: [
        { name: 'ob_refcnt', size: '8B', color: '#FBBF24', zh: '引用计数', en: 'refcount' },
        { name: 'ob_type', size: '8B', color: '#A78BFA', zh: '→ list 类型', en: '→ list type' },
        { name: 'ob_size', size: '8B', color: '#22D3EE', zh: 'len() 元素数', en: 'len()' },
        { name: 'ob_item*', size: '8B', color: '#F472B6', zh: '→ 元素指针数组', en: '→ item array' },
        { name: 'allocated', size: '8B', color: '#F87171', zh: '已分配容量', en: 'allocated cap' },
        { name: 'item[0..N]*', size: '8×N', color: '#22C55E', zh: '每个元素是指针(8B)', en: 'each item is ptr' },
      ],
      noteZh: '空 list 56B；每元素额外 8B 指针 + 元素本身。类似 C++ vector<PyObject*>。',
      noteEn: 'Empty list 56B; each item adds 8B pointer + the item itself. Like vector<PyObject*>.',
    },
    dict: {
      titleZh: 'dict 对象 (PyDictObject, 3.6+)', titleEn: 'dict object (3.6+ compact)', total: '64+ 字节',
      fields: [
        { name: 'ob_refcnt', size: '8B', color: '#FBBF24', zh: '引用计数', en: 'refcount' },
        { name: 'ob_type', size: '8B', color: '#A78BFA', zh: '→ dict 类型', en: '→ dict type' },
        { name: 'ob_size', size: '8B', color: '#22D3EE', zh: 'len() 键值对数', en: 'len()' },
        { name: 'ma_keys*', size: '8B', color: '#F472B6', zh: '→ 紧凑 keys 数组', en: '→ keys array' },
        { name: 'ma_values*', size: '8B', color: '#22C55E', zh: '→ values 数组(或内联)', en: '→ values array' },
        { name: 'keys/vals', size: '可变', color: '#F87171', zh: '稀疏索引+紧凑entries', en: 'sparse idx+entries' },
      ],
      noteZh: '3.6+ 紧凑 dict：两个数组，插入有序，内存比旧版省 20-25%。详见性能优化页。',
      noteEn: '3.6+ compact dict: two arrays, insertion-ordered, ~20-25% smaller. See optimization page.',
    },
    type: {
      titleZh: 'type 对象 (PyTypeObject)', titleEn: 'type object (PyTypeObject)', total: '~400+ 字节',
      fields: [
        { name: 'ob_refcnt', size: '8B', color: '#FBBF24', zh: '引用计数', en: 'refcount' },
        { name: 'ob_type', size: '8B', color: '#A78BFA', zh: '→ type (自举)', en: '→ type (self)' },
        { name: 'ob_size', size: '8B', color: '#22D3EE', zh: '变长头', en: 'var header' },
        { name: 'tp_name*', size: '8B', color: '#F472B6', zh: '"int"/"Dog"', en: 'type name' },
        { name: 'tp_basicsize', size: '8B', color: '#22C55E', zh: '实例大小', en: 'instance size' },
        { name: 'slots...', size: '~80', color: '#F87171', zh: '协议槽:tp_dealloc/nb_add...', en: 'slots:tp_dealloc/nb_add...' },
      ],
      noteZh: '类型本身是个大对象，持有所有实例共享的方法表与协议槽。type(type) is type。',
      noteEn: 'The type itself is a large object, holding method tables shared by all instances. type(type) is type.',
    },
  };

  function lang(): 'zh' | 'en' { return document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh'; }

  function render(key: string) {
    const data = OBJS[key];
    if (!data) return;
    svg.innerHTML = '';

    const title = document.createElementNS(SVGNS, 'text');
    title.setAttribute('x', '20'); title.setAttribute('y', '25');
    title.setAttribute('font-size', '15'); title.setAttribute('font-weight', '700');
    title.setAttribute('fill', '#22D3EE');
    title.textContent = `${lang() === 'en' ? data.titleEn : data.titleZh}  ·  ${data.total}`;
    svg.appendChild(title);

    // 内存块纵向排列
    const startX = 60, startY = 50, blockW = 280, fieldH = 32;
    for (let i = 0; i < data.fields.length; i++) {
      const f = data.fields[i];
      const y = startY + i * fieldH;
      const rect = document.createElementNS(SVGNS, 'rect');
      rect.setAttribute('x', String(startX)); rect.setAttribute('y', String(y));
      rect.setAttribute('width', String(blockW)); rect.setAttribute('height', String(fieldH - 4));
      rect.setAttribute('rx', '4'); rect.setAttribute('fill', f.color + '22');
      rect.setAttribute('stroke', f.color + '88'); rect.setAttribute('stroke-width', '1.5');
      svg.appendChild(rect);

      const name = document.createElementNS(SVGNS, 'text');
      name.setAttribute('x', String(startX + 12)); name.setAttribute('y', String(y + 20));
      name.setAttribute('font-size', '12'); name.setAttribute('font-weight', '600');
      name.setAttribute('fill', f.color); name.setAttribute('font-family', 'monospace');
      name.textContent = f.name;
      svg.appendChild(name);

      const sz = document.createElementNS(SVGNS, 'text');
      sz.setAttribute('x', String(startX + blockW - 12)); sz.setAttribute('y', String(y + 20));
      sz.setAttribute('text-anchor', 'end'); sz.setAttribute('font-size', '11');
      sz.setAttribute('fill', '#94A3B8'); sz.setAttribute('font-family', 'monospace');
      sz.textContent = f.size;
      svg.appendChild(sz);
    }

    // C++ 对比框（右侧）
    const cx = 420, cy = 50;
    const card = document.createElementNS(SVGNS, 'rect');
    card.setAttribute('x', String(cx)); card.setAttribute('y', String(cy));
    card.setAttribute('width', '360'); card.setAttribute('height', String(data.fields.length * fieldH - 4));
    card.setAttribute('rx', '8'); card.setAttribute('fill', '#22C55E11');
    card.setAttribute('stroke', '#22C55E55'); card.setAttribute('stroke-width', '1.5');
    svg.appendChild(card);

    const ct = document.createElementNS(SVGNS, 'text');
    ct.setAttribute('x', String(cx + 16)); ct.setAttribute('y', String(cy + 24));
    ct.setAttribute('font-size', '13'); ct.setAttribute('font-weight', '700');
    ct.setAttribute('fill', '#22C55E');
    ct.textContent = lang() === 'en' ? 'C++ Equivalent' : 'C++ 对比';
    svg.appendChild(ct);

    const compare: Record<string, [string, string]> = {
      int: ['int (4B, 栈上)', 'int (4B, stack)'],
      list: ['vector<T> (~24B头)', 'vector<T> (~24B header)'],
      dict: ['unordered_map (~仅数据)', 'unordered_map (~data only)'],
      type: ['编译期类型(运行时无)', 'compile-time (none at runtime)'],
    };
    const [zh, en] = compare[key];
    const cmp = document.createElementNS(SVGNS, 'text');
    cmp.setAttribute('x', String(cx + 16)); cmp.setAttribute('y', String(cy + 48));
    cmp.setAttribute('font-size', '12'); cmp.setAttribute('fill', '#CBD5E1');
    cmp.setAttribute('font-family', 'monospace');
    cmp.textContent = lang() === 'en' ? en : zh;
    svg.appendChild(cmp);

    // 注释
    const note = document.createElementNS(SVGNS, 'text');
    const noteY = startY + data.fields.length * fieldH + 16;
    // wrap note roughly
    const noteText = lang() === 'en' ? data.noteEn : data.noteZh;
    const words = noteText.split('');
    let line = ''; let lineIdx = 0;
    for (const ch of words) {
      line += ch;
      if (line.length > 38) {
        const t = document.createElementNS(SVGNS, 'text');
        t.setAttribute('x', String(startX)); t.setAttribute('y', String(noteY + lineIdx * 18));
        t.setAttribute('font-size', '11'); t.setAttribute('fill', '#94A3B8');
        t.textContent = line;
        svg.appendChild(t);
        line = ''; lineIdx++;
      }
    }
    if (line) {
      const t = document.createElementNS(SVGNS, 'text');
      t.setAttribute('x', String(startX)); t.setAttribute('y', String(noteY + lineIdx * 18));
      t.setAttribute('font-size', '11'); t.setAttribute('fill', '#94A3B8');
      t.textContent = line;
      svg.appendChild(t);
    }
  }

  function setActive(key: string) {
    objBtns.forEach(b => b.classList.toggle('btn-primary', b.dataset.obj === key));
    render(key);
  }
  objBtns.forEach(b => b.addEventListener('click', () => setActive(b.dataset.obj!)));
  document.addEventListener('langchange', () => {
    const active = document.querySelector<HTMLButtonElement>('.obj-btn.btn-primary');
    render(active?.dataset.obj || 'int');
  });
  setActive('int');
</script>
