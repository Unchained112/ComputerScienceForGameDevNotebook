<script>
  // Lambda 捕获方式可视化
  const SVGNS = 'http://www.w3.org/2000/svg';
  const svg = document.getElementById('lambda-svg') as unknown as SVGSVGElement;
  const lambdaBtns = document.querySelectorAll<HTMLButtonElement>('.lambda-btn');

  interface CaptureData {
    titleZh: string; titleEn: string; color: string;
    syntax: string;
    descZh: string; descEn: string;
    exampleZh: string; exampleEn: string;
  }

  const CAPTURES: Record<string, CaptureData> = {
    value: {
      titleZh: '[=] 值捕获', titleEn: '[=] by value', color: '#22C55E',
      syntax: '[=]() { /* 使用 x, y 的拷贝 */ }',
      descZh: '拷贝所有外部变量的当前值。Lambda 内修改不影响外部（除非 mutable）。',
      descEn: 'Copies all outer variables by value. Modifications inside do not affect outer (unless mutable).',
      exampleZh: 'auto f = [=]() { return x + y; };  // 快照',
      exampleEn: 'auto f = [=]() { return x + y; };  // snapshot',
    },
    ref: {
      titleZh: '[&] 引用捕获', titleEn: '[&] by reference', color: '#FBBF24',
      syntax: '[&]() { /* 可修改 x, y */ }',
      descZh: '引用所有外部变量。Lambda 内修改直接影响外部。注意生命周期！',
      descEn: 'References all outer variables. Modifications inside affect outer. Mind lifetimes!',
      exampleZh: 'auto f = [&]() { x = 999; };  // 修改外部',
      exampleEn: 'auto f = [&]() { x = 999; };  // modifies outer',
    },
    move: {
      titleZh: '[=,&x=move] 移动捕获', titleEn: '[=,&x=move]', color: '#A78BFA',
      syntax: '[p = std::move(ptr)]() { /* 使用 p */ }',
      descZh: 'C++14 初始化捕获：将外部资源移动到 Lambda 内部。适合智能指针、大型对象。',
      descEn: 'C++14 init capture: move outer resources into the lambda. Good for smart pointers, large objects.',
      exampleZh: 'auto f = [p = std::move(ptr)]() { return *p; };',
      exampleEn: 'auto f = [p = std::move(ptr)]() { return *p; };',
    },
    this: {
      titleZh: '[this] 捕获 this', titleEn: '[this]', color: '#22D3EE',
      syntax: '[this]() { /* 访问成员 */ }',
      descZh: '捕获类实例指针，可访问成员变量和成员函数。C++20 推荐 [=*this] 值捕获整个对象。',
      descEn: 'Captures class instance pointer, accessing members. C++20 recommends [=*this] to copy the object.',
      exampleZh: 'auto cb = [this]() { score++; };  // 访问成员',
      exampleEn: 'auto cb = [this]() { score++; };  // access member',
    },
  };

  function lang(): 'zh' | 'en' { return document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh'; }

  function render(cap: string) {
    const data = CAPTURES[cap];
    if (!data) return;
    svg.innerHTML = '';

    // 标题
    const title = document.createElementNS(SVGNS, 'text');
    title.setAttribute('x', '400'); title.setAttribute('y', '35');
    title.setAttribute('text-anchor', 'middle'); title.setAttribute('font-size', '18');
    title.setAttribute('font-weight', '700'); title.setAttribute('fill', data.color);
    title.setAttribute('font-family', 'monospace');
    title.textContent = lang() === 'en' ? data.titleEn : data.titleZh;
    svg.appendChild(title);

    // 语法代码块
    const codeY = 65;
    const codeBg = document.createElementNS(SVGNS, 'rect');
    codeBg.setAttribute('x', '100'); codeBg.setAttribute('y', String(codeY));
    codeBg.setAttribute('width', '600'); codeBg.setAttribute('height', '45');
    codeBg.setAttribute('rx', '8'); codeBg.setAttribute('fill', 'rgba(11,17,32,0.6)');
    codeBg.setAttribute('stroke', data.color + '44'); codeBg.setAttribute('stroke-width', '1.5');
    svg.appendChild(codeBg);

    const code = document.createElementNS(SVGNS, 'text');
    code.setAttribute('x', '120'); code.setAttribute('y', String(codeY + 28));
    code.setAttribute('font-size', '14'); code.setAttribute('fill', '#CBD5E1');
    code.setAttribute('font-family', 'monospace');
    code.textContent = data.syntax;
    svg.appendChild(code);

    // 描述
    const descText = lang() === 'en' ? data.descEn : data.descZh;
    const words = descText.split('');
    let line = '';
    let dy = 0;
    const descY = 135;
    for (let i = 0; i < words.length; i++) {
      const test = line + words[i];
      if (test.length > 55) {
        const t = document.createElementNS(SVGNS, 'text');
        t.setAttribute('x', '400'); t.setAttribute('y', String(descY + dy));
        t.setAttribute('text-anchor', 'middle'); t.setAttribute('font-size', '13');
        t.setAttribute('fill', '#94A3B8');
        t.textContent = line;
        svg.appendChild(t);
        line = words[i];
        dy += 20;
      } else {
        line = test;
      }
    }
    if (line) {
      const t = document.createElementNS(SVGNS, 'text');
      t.setAttribute('x', '400'); t.setAttribute('y', String(descY + dy));
      t.setAttribute('text-anchor', 'middle'); t.setAttribute('font-size', '13');
      t.setAttribute('fill', '#94A3B8');
      t.textContent = line;
      svg.appendChild(t);
    }

    // 示例代码
    const exY = descY + dy + 35;
    const exBg = document.createElementNS(SVGNS, 'rect');
    exBg.setAttribute('x', '100'); exBg.setAttribute('y', String(exY));
    exBg.setAttribute('width', '600'); exBg.setAttribute('height', '45');
    exBg.setAttribute('rx', '8'); exBg.setAttribute('fill', data.color + '11');
    exBg.setAttribute('stroke', data.color + '55'); exBg.setAttribute('stroke-width', '1.5');
    svg.appendChild(exBg);

    const exLabel = document.createElementNS(SVGNS, 'text');
    exLabel.setAttribute('x', '110'); exLabel.setAttribute('y', String(exY + 16));
    exLabel.setAttribute('font-size', '11'); exLabel.setAttribute('fill', data.color);
    exLabel.setAttribute('font-weight', '600');
    exLabel.textContent = lang() === 'en' ? 'Example' : '示例';
    svg.appendChild(exLabel);

    const exCode = document.createElementNS(SVGNS, 'text');
    exCode.setAttribute('x', '120'); exCode.setAttribute('y', String(exY + 36));
    exCode.setAttribute('font-size', '13'); exCode.setAttribute('fill', '#CBD5E1');
    exCode.setAttribute('font-family', 'monospace');
    exCode.textContent = lang() === 'en' ? data.exampleEn : data.exampleZh;
    svg.appendChild(exCode);
  }

  function setActive(cap: string) {
    lambdaBtns.forEach(b => b.classList.toggle('btn-primary', b.dataset.capture === cap));
    render(cap);
  }
  lambdaBtns.forEach(b => b.addEventListener('click', () => setActive(b.dataset.capture!)));
  document.addEventListener('langchange', () => {
    const active = document.querySelector<HTMLButtonElement>('.lambda-btn.btn-primary');
    render(active?.dataset.capture || 'value');
  });
  setActive('value');
</script>
