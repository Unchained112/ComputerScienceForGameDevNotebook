<script>
  // RPC 调用流程时序图动画
  // 五条泳道: Client / Client Stub / Network / Server Stub / Server
  const LANES = [
    { x: 80,  label: { zh: '客户端', en: 'Client' } },
    { x: 230, label: { zh: '客户端桩', en: 'Client Stub' } },
    { x: 400, label: { zh: '网络', en: 'Network' } },
    { x: 570, label: { zh: '服务端桩', en: 'Server Stub' } },
    { x: 720, label: { zh: '服务端', en: 'Server' } },
  ];
  const TOP = 60, BOT = 340;
  const SVGNS = 'http://www.w3.org/2000/svg';
  const svg = document.getElementById('rpc-svg') as unknown as SVGSVGElement;
  const stateEl = document.getElementById('rpc-state');

  // 每步: from lane index, to lane index, label, direction(down/right-up)
  interface Step { from: number; to: number; labelZh: string; labelEn: string; color: string; }
  const STEPS: Step[] = [
    { from: 0, to: 1, labelZh: '1. 调用 GetUser(id)', labelEn: '1. Call GetUser(id)', color: '#22D3EE' },
    { from: 1, to: 2, labelZh: '2. 序列化参数 (marshal)', labelEn: '2. Marshal params', color: '#FBBF24' },
    { from: 2, to: 3, labelZh: '3. 传输请求字节流', labelEn: '3. Transmit request bytes', color: '#A78BFA' },
    { from: 3, to: 4, labelZh: '4. 反序列化 + 调用实现', labelEn: '4. Unmarshal + invoke impl', color: '#22C55E' },
    { from: 4, to: 3, labelZh: '5. 返回结果', labelEn: '5. Return result', color: '#22C55E' },
    { from: 3, to: 2, labelZh: '6. 序列化返回值', labelEn: '6. Marshal return value', color: '#FBBF24' },
    { from: 2, to: 1, labelZh: '7. 传输响应字节流', labelEn: '7. Transmit response bytes', color: '#A78BFA' },
    { from: 1, to: 0, labelZh: '8. 反序列化 + 返回给调用方', labelEn: '8. Unmarshal + return to caller', color: '#22D3EE' },
  ];

  const COL_BG = 'rgba(148,163,184,0.15)';
  const COL_LINE = 'rgba(148,163,184,0.3)';
  const COL_TXT = '#0B1120';
  const COL_LBL = '#94A3B8';

  let curStepIdx = -1;
  let frames: { stepIdx: number }[] = [];

  function lang(): 'zh' | 'en' {
    return document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh';
  }

  function render(stepIdx: number) {
    curStepIdx = stepIdx;
    svg.innerHTML = '';

    // 泳道背景 + 生命线
    for (const lane of LANES) {
      const rect = document.createElementNS(SVGNS, 'rect');
      rect.setAttribute('x', String(lane.x - 60));
      rect.setAttribute('y', String(TOP - 30));
      rect.setAttribute('width', '120');
      rect.setAttribute('height', String(BOT - TOP + 60));
      rect.setAttribute('fill', COL_BG);
      rect.setAttribute('rx', '8');
      svg.appendChild(rect);

      const line = document.createElementNS(SVGNS, 'line');
      line.setAttribute('x1', String(lane.x)); line.setAttribute('y1', String(TOP));
      line.setAttribute('x2', String(lane.x)); line.setAttribute('y2', String(BOT));
      line.setAttribute('stroke', COL_LINE); line.setAttribute('stroke-width', '1.5');
      line.setAttribute('stroke-dasharray', '4 4');
      svg.appendChild(line);

      // 泳道标题
      const t = document.createElementNS(SVGNS, 'text');
      t.setAttribute('x', String(lane.x)); t.setAttribute('y', String(TOP - 12));
      t.setAttribute('text-anchor', 'middle'); t.setAttribute('font-size', '12');
      t.setAttribute('font-weight', '600'); t.setAttribute('fill', '#E2E8F0');
      t.textContent = lang() === 'en' ? lane.label.en : lane.label.zh;
      svg.appendChild(t);
    }

    // 已执行的步骤箭头
    const yStart = TOP + 20;
    const yStep = (BOT - TOP - 40) / STEPS.length;
    for (let i = 0; i <= stepIdx && i < STEPS.length; i++) {
      const s = STEPS[i];
      const y = yStart + i * yStep;
      const x1 = LANES[s.from].x;
      const x2 = LANES[s.to].x;
      const isActive = i === stepIdx;
      const color = isActive ? s.color : 'rgba(148,163,184,0.4)';

      // 箭头线
      const line = document.createElementNS(SVGNS, 'line');
      line.setAttribute('x1', String(x1)); line.setAttribute('y1', String(y));
      line.setAttribute('x2', String(x2)); line.setAttribute('y2', String(y));
      line.setAttribute('stroke', color);
      line.setAttribute('stroke-width', isActive ? '2.5' : '1.5');
      line.setAttribute('marker-end', 'url(#arrowhead)');
      svg.appendChild(line);

      // 箭头标记（手绘三角形）
      const dir = x2 > x1 ? 1 : -1;
      const tri = document.createElementNS(SVGNS, 'polygon');
      tri.setAttribute('points', `${x2},${y} ${x2 - dir * 8},${y - 5} ${x2 - dir * 8},${y + 5}`);
      tri.setAttribute('fill', color);
      svg.appendChild(tri);

      // 步骤标签
      const midX = (x1 + x2) / 2;
      const lbl = document.createElementNS(SVGNS, 'text');
      lbl.setAttribute('x', String(midX)); lbl.setAttribute('y', String(y - 8));
      lbl.setAttribute('text-anchor', 'middle'); lbl.setAttribute('font-size', '11');
      lbl.setAttribute('fill', isActive ? color : COL_LBL);
      if (isActive) lbl.setAttribute('font-weight', '700');
      lbl.textContent = lang() === 'en' ? s.labelEn : s.labelZh;
      svg.appendChild(lbl);

      // 激活条（当前步骤的源/目标泳道高亮）
      if (isActive) {
        for (const li of [s.from, s.to]) {
          const bar = document.createElementNS(SVGNS, 'rect');
          bar.setAttribute('x', String(LANES[li].x - 3));
          bar.setAttribute('y', String(y - 8));
          bar.setAttribute('width', '6');
          bar.setAttribute('height', '16');
          bar.setAttribute('fill', color);
          bar.setAttribute('rx', '2');
          bar.setAttribute('opacity', '0.6');
          svg.appendChild(bar);
        }
      }
    }

    // 状态文字
    if (stateEl) {
      if (stepIdx >= 0 && stepIdx < STEPS.length) {
        const s = STEPS[stepIdx];
        stateEl.textContent = lang() === 'en' ? s.labelEn : s.labelZh;
      } else {
        stateEl.textContent = lang() === 'en' ? 'Ready' : '就绪';
      }
    }
  }

  function buildFrames() {
    frames = STEPS.map((_, i) => ({ stepIdx: i }));
  }

  let idx = 0;
  let timer: number | null = null;

  function langText(key: string): string {
    const l = lang();
    const el = document.querySelector(`[data-ui="${key}"][data-lang="${l}"]`);
    return el ? (el.textContent || '') : '';
  }

  function stop() {
    if (timer !== null) { clearInterval(timer); timer = null; }
    const b = document.getElementById('rpc-play');
    if (b) b.innerHTML = langText('play');
  }
  function rebuild() {
    stop(); buildFrames(); idx = 0; render(-1); if (stateEl) stateEl.textContent = '';
  }
  function advance(): boolean {
    if (idx < frames.length) { render(frames[idx].stepIdx); idx++; return true; }
    return false;
  }
  function play() {
    if (timer !== null) { stop(); return; }
    const b = document.getElementById('rpc-play');
    if (b) b.innerHTML = langText('pause');
    timer = window.setInterval(() => { if (!advance()) stop(); }, 800);
  }

  document.getElementById('rpc-play')?.addEventListener('click', play);
  document.getElementById('rpc-step')?.addEventListener('click', () => { stop(); advance(); });
  document.getElementById('rpc-reset')?.addEventListener('click', rebuild);
  document.addEventListener('langchange', () => {
    if (timer === null) { const b = document.getElementById('rpc-play'); if (b) b.innerHTML = langText('play'); }
    if (curStepIdx >= 0) render(curStepIdx); else render(-1);
  });
  rebuild();
</script>
