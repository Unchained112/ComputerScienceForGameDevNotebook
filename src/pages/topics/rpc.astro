    <!-- 自定义 UDP RPC -->
    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">自定义 UDP RPC：实时对战通信</span><span slot="en">Custom UDP RPC: Real-Time Combat</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh">动作游戏（FPS/MOBA）对延迟极度敏感，TCP 的重传和拥塞控制会引入抖动。游戏通常在 <b>UDP</b> 之上自建 RPC 协议，按可靠性分为两类通道：<b class="text-func-red">不可靠通道</b>（位置同步、动画状态——丢失一帧无所谓，下一帧覆盖即可）；<b class="text-func-green">可靠通道</b>（开火命中、技能释放——必须到达，用 ACK + 序号重传）。典型实现：每个 RPC 包带 <code>seq</code> 序号，可靠 RPC 额外等 ACK，超时重传；不可靠 RPC 直接发送不等待。</span><span slot="en">Action games (FPS/MOBA) are latency-sensitive; TCP's retransmission and congestion control cause jitter. Games typically build custom RPC protocols over <b>UDP</b>, splitting into two channels: <b class="text-func-red">unreliable</b> (position sync, animation state—losing one frame is fine, the next overwrites); <b class="text-func-green">reliable</b> (fire hit, skill cast—must arrive, use ACK + sequence retransmission). Typical implementation: each RPC packet carries a <code>seq</code> number; reliable RPCs wait for ACK with timeout retransmit; unreliable RPCs fire-and-forget.</span></Bilingual></p>
      <CodeTabs
  cpp={`<pre><code>// 自定义 UDP RPC 协议（简化版）
#pragma pack(push, 1)
struct RpcPacket &#123;
    uint16_t seq;        // 序号（检测丢包/乱序）
    uint16_t rpc_id;     // RPC 类型: 0x01=Move 0x02=Fire 0x03=Skill
    uint8_t  reliable;   // 1=需要ACK  0=不可靠
    uint8_t  data[56];   // 负载（固定大小，避免分片）
&#125;;
#pragma pack(pop)

// 客户端：发送不可靠 RPC（位置同步）
void sendMoveUDP(int sock, uint16_t seq, Vec3 pos, float yaw) &#123;
    RpcPacket pkt;
    pkt.seq = seq;
    pkt.rpc_id = 0x01;       // Move
    pkt.reliable = 0;        // 不可靠：发完不等
    memcpy(pkt.data, &amp;pos, sizeof(pos));
    memcpy(pkt.data + 12, &amp;yaw, sizeof(yaw));
    sendto(sock, &amp;pkt, sizeof(pkt), 0, &amp;serverAddr, sizeof(serverAddr));
    // 不等 ACK，下一帧再发新的位置
&#125;

// 客户端：发送可靠 RPC（开火）
void sendFireReliable(int sock, uint16_t&amp; seq, Vec3 target) &#123;
    RpcPacket pkt;
    pkt.seq = ++seq;
    pkt.rpc_id = 0x02;       // Fire
    pkt.reliable = 1;        // 可靠：需要 ACK
    memcpy(pkt.data, &amp;target, sizeof(target));
    // 加入重传队列，启动超时定时器
    pendingAcks[pkt.seq] = &#123;pkt, GetTimeMs()&#125;;
    sendto(sock, &amp;pkt, sizeof(pkt), 0, &amp;serverAddr, sizeof(serverAddr));
&#125;

// 客户端：ACK 检查线程
void checkRetransmit(int sock) &#123;
    uint64_t now = GetTimeMs();
    for (auto&amp; [seq, entry] : pendingAcks) &#123;
        if (now - entry.sendTime &gt; 100) &#123;  // 100ms 超时
            // 重传
            sendto(sock, &amp;entry.pkt, sizeof(entry.pkt),
                   0, &amp;serverAddr, sizeof(serverAddr));
            entry.sendTime = now;  // 重置计时
        &#125;
    &#125;
&#125;

// 服务器：接收并分发
void onPacket(int sock) &#123;
    RpcPacket pkt;
    recvfrom(sock, &amp;pkt, sizeof(pkt), 0, nullptr, nullptr);
    if (pkt.reliable) &#123;
        sendAck(sock, pkt.seq);  // 回复 ACK
    &#125;
    switch (pkt.rpc_id) &#123;
        case 0x01: onMove(pkt.data); break;   // 位置同步
        case 0x02: onFire(pkt.data); break;   // 开火处理
        case 0x03: onSkill(pkt.data); break;  // 技能释放
    &#125;
&#125;</code></pre>`}
  py={`<pre><code>import socket, struct, time, threading

# 自定义 UDP RPC 协议（简化版）
# 包格式: seq(2) + rpc_id(2) + reliable(1) + data(56) = 61 bytes
PACK_FMT = "&lt;HHB56s"

class GameRpcClient:
    def __init__(self, server_addr):
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.server = server_addr
        self.seq = 0
        self.pending_acks = {}  # seq -> (packet, send_time)
        self.lock = threading.Lock()
        # 启动重传线程
        t = threading.Thread(target=self._retransmit_loop, daemon=True)
        t.start()

    def send_unreliable(self, rpc_id, data: bytes):
        """不可靠 RPC：位置同步、动画状态"""
        self.seq += 1
        pkt = struct.pack(PACK_FMT, self.seq, rpc_id, 0, data.ljust(56, b'\\x00'))
        self.sock.sendto(pkt, self.server)  # 发完不等

    def send_reliable(self, rpc_id, data: bytes):
        """可靠 RPC：开火、技能释放"""
        self.seq += 1
        pkt = struct.pack(PACK_FMT, self.seq, rpc_id, 1, data.ljust(56, b'\\x00'))
        with self.lock:
            self.pending_acks[self.seq] = (pkt, time.time())
        self.sock.sendto(pkt, self.server)

    def _retransmit_loop(self):
        """每 50ms 检查超时未 ACK 的包，重传"""
        while True:
            time.sleep(0.05)
            now = time.time()
            with self.lock:
                for seq, (pkt, t) in list(self.pending_acks.items()):
                    if now - t &gt; 0.1:  # 100ms 超时
                        self.sock.sendto(pkt, self.server)
                        self.pending_acks[seq] = (pkt, now)

    def on_ack(self, seq):
        """收到 ACK，移出重传队列"""
        with self.lock:
            self.pending_acks.pop(seq, None)

# 使用示例
client = GameRpcClient(("10.0.1.5", 7777))
# 不可靠：每帧发送位置（丢了没关系，下帧覆盖）
client.send_unreliable(0x01, struct.pack("&lt;fff", x, y, z))
# 可靠：开火请求（必须到达）
client.send_reliable(0x02, struct.pack("&lt;fff", tx, ty, tz))</code></pre>`}
      />
