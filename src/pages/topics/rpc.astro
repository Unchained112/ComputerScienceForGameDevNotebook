    <!-- Unreal Engine RPC -->
    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">Unreal Engine RPC：网络复制</span><span slot="en">Unreal Engine RPC: Network Replication</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh">Unreal Engine 的网络同步以 <b>Server Authority（服务器权威）</b>为核心：客户端不能直接修改游戏状态，必须通过 RPC 请求服务器执行。三种 RPC 类型：<b class="text-func-amber">Server RPC</b>——客户端调用、服务器执行（如开火请求）；<b class="text-primary-cyan">Client RPC</b>——服务器调用、指定客户端执行（如受到伤害的屏幕特效）；<b class="text-func-green">NetMulticast</b>——服务器调用、所有客户端执行（如爆炸特效）。用 <code>UFUNCTION(Server/Client/NetMulticast)</code> 宏声明。</span><span slot="en">Unreal Engine's networking is built on <b>Server Authority</b>: clients can't directly mutate game state—they must request the server via RPC. Three RPC types: <b class="text-func-amber">Server RPC</b>—called on client, executed on server (e.g., fire request); <b class="text-primary-cyan">Client RPC</b>—called on server, executed on a specific client (e.g., damage VFX); <b class="text-func-green">NetMulticast</b>—called on server, executed on all clients (e.g., explosion VFX). Declared with <code>UFUNCTION(Server/Client/NetMulticast)</code> specifiers.</span></Bilingual></p>
      <div class="overflow-x-auto mb-4">
        <table class="w-full text-sm">
          <thead class="text-ink-muted text-left"><tr class="border-b border-[color:var(--glass-border)]"><th class="py-2 pr-4"><Bilingual><span slot="zh">类型</span><span slot="en">Type</span></Bilingual></th><th class="py-2 pr-4"><Bilingual><span slot="zh">调用方</span><span slot="en">Caller</span></Bilingual></th><th class="py-2 pr-4"><Bilingual><span slot="zh">执行方</span><span slot="en">Executor</span></Bilingual></th><th class="py-2 pr-4"><Bilingual><span slot="zh">游戏场景</span><span slot="en">Game scenario</span></Bilingual></th></tr></thead>
          <tbody class="text-ink">
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-func-amber">Server RPC</td><td class="py-2 pr-4">Client</td><td class="py-2 pr-4">Server</td><td class="py-2 pr-4"><Bilingual><span slot="zh">请求开火、移动、拾取物品</span><span slot="en">Request fire, move, pick up item</span></Bilingual></td></tr>
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-primary-cyan">Client RPC</td><td class="py-2 pr-4">Server</td><td class="py-2 pr-4">指定 Client</td><td class="py-2 pr-4"><Bilingual><span slot="zh">受击红屏、个人提示音</span><span slot="en">Damage red-screen, personal notification</span></Bilingual></td></tr>
            <tr><td class="py-2 pr-4 text-func-green">NetMulticast</td><td class="py-2 pr-4">Server</td><td class="py-2 pr-4">All Clients</td><td class="py-2 pr-4"><Bilingual><span slot="zh">爆炸特效、全局广播</span><span slot="en">Explosion VFX, global broadcast</span></Bilingual></td></tr>
          </tbody>
        </table>
      </div>
      <CodeTabs
  cpp={`<pre><code>// ========== Unreal Engine RPC 示例（C++） ==========
// MyWeapon.h
#pragma once
#include "CoreMinimal.h"
#include "GameFramework/Actor.h"
#include "MyWeapon.generated.h"

UCLASS()
class MYGAME_API AMyWeapon : public AActor &#123;
    GENERATED_BODY()
public:
    // Server RPC：客户端请求开火，服务器验证后执行
    UFUNCTION(Server, Reliable, WithValidation)
    void ServerFire(const FVector&amp; TargetLocation);

    // Client RPC：服务器通知某客户端播放伤害特效
    UFUNCTION(Client, Unreliable)
    void ClientTakeDamage(int32 Damage, const FVector&amp; FromPos);

    // NetMulticast：服务器广播爆炸特效给所有客户端
    UFUNCTION(NetMulticast, Unreliable)
    void MulticastExplosion(const FVector&amp; Pos, float Radius);

    UPROPERTY(Replicated, EditAnywhere)
    int32 Ammo = 30;  // 服务器权威，自动复制到客户端
&#125;;

// MyWeapon.cpp
void AMyWeapon::ServerFire_Implementation(const FVector&amp; TargetLocation) &#123;
    // 在服务器上执行：验证权限、扣除弹药、判定命中
    if (Ammo &lt;= 0) return;
    Ammo--;
    // 服务器执行射线检测...
    if (bHit) &#123;
        // 通知被击中的客户端播放受击特效
        ClientTakeDamage(Damage, HitLocation);
        // 广播给所有人：播放命中特效
        MulticastExplosion(HitLocation, 50.f);
    &#125;
&#125;

bool AMyWeapon::ServerFire_Validate(const FVector&amp; TargetLocation) &#123;
    // 反作弊验证：检查冷却、弹药、权限
    return Ammo &gt; 0 &amp;&amp; (GetWorld()-&gt;GetTimeSeconds() - LastFireTime) &gt; 0.1f;
&#125;

void AMyWeapon::ClientTakeDamage_Implementation(int32 Dmg, const FVector&amp; From) &#123;
    // 仅在目标客户端执行：屏幕红屏、血量 UI 闪烁
    ShowDamageVignette(Dmg, From);
&#125;

void AMyWeapon::MulticastExplosion_Implementation(const FVector&amp; Pos, float R) &#123;
    // 在所有客户端执行：播放粒子特效与音效
    SpawnExplosionParticle(Pos, R);
&#125;

// 蓝图中的等价写法：
// ServerFire  →  "Switch has Authority" →  Authority 分支执行
// ClientTakeDamage →  "Run on Owning Client"
// MulticastExplosion →  "Run on Server" + Replicates</code></pre>`}
  py={`<pre><code># ========== Unreal Python (Blueprint 伪代码) ==========
# 注意：Unreal 原生不使用 Python 做网络 RPC，
# 以下为蓝图逻辑的 Python 伪代码表示

# Server RPC：客户端请求开火
def server_fire(target_location):
    """在服务器执行：验证+扣弹药+判定命中"""
    if weapon.ammo &lt;= 0:
        return
    weapon.ammo -= 1
    hit = do_ray_check(target_location)
    if hit:
        # Client RPC → 仅目标客户端
        client_take_damage(hit.player, damage, hit.location)
        # NetMulticast → 所有客户端
        multicast_explosion(hit.location, radius=50.0)

# Client RPC：受击红屏
def client_take_damage(damage, from_pos):
    """仅目标客户端执行：UI 反馈"""
    hud.show_damage_vignette(damage, from_pos)
    audio.play_hit_sound()

# NetMulticast：爆炸特效
def multicast_explosion(pos, radius):
    """所有客户端执行：粒子+音效"""
    spawn_explosion_particle(pos, radius)
    audio.play_explosion_sound()

# 可靠性说明：
# Reliable   = 保证到达，保证顺序（如开火、拾取）
# Unreliable = 尽力而为，可能丢失（如特效、位置插值）</code></pre>`}
