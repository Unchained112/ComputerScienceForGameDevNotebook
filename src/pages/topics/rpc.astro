    <!-- gRPC -->
    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">gRPC：游戏后端微服务</span><span slot="en">gRPC: Game Backend Microservices</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh">gRPC 基于 <b>HTTP/2</b> 多路复用 + <b>Protocol Buffers</b> 序列化，支持四种调用模式：一元（Unary）、服务端流、客户端流、双向流。游戏后端典型用法：<b>匹配服务</b>（一元：请求匹配→返回房间号）、<b>排行榜</b>（服务端流：一次拉取 Top100）、<b>背包同步</b>（一元：增删道具）。先用 <code>.proto</code> 定义接口，再用 <code>protoc</code> 生成多语言 Stub。</span><span slot="en">gRPC builds on <b>HTTP/2</b> multiplexing + <b>Protocol Buffers</b> serialization, supporting four call patterns: unary, server-streaming, client-streaming, and bidirectional streaming. Typical game backend usage: <b>matchmaking</b> (unary: request → room ID), <b>leaderboard</b> (server-streaming: fetch Top 100 in one call), <b>inventory sync</b> (unary: add/remove items). Define the interface in <code>.proto</code>, then generate multi-language stubs with <code>protoc</code>.</span></Bilingual></p>
      <CodeTabs
  cpp={`<pre><code>// ========== game.proto ==========
syntax = "proto3";
package game;

service MatchService &#123;
    // 一元 RPC：请求匹配，返回房间号
    rpc RequestMatch (MatchRequest) returns (MatchResponse);
    // 服务端流：拉取排行榜
    rpc GetLeaderboard (PageRequest) returns (stream ScoreEntry);
&#125;

message MatchRequest &#123;
    string player_id = 1;
    int32  rank = 2;          // 当前段位
    string region = 3;        // 地区: ap/cn/eu/na
&#125;

message MatchResponse &#123;
    string room_id = 1;
    string server_addr = 2;
    repeated string teammates = 3;
&#125;

message ScoreEntry &#123;
    string player_id = 1;
    int32  score = 2;
    int32  rank = 3;
&#125;

// ========== C++ 服务端 ==========
class MatchServiceImpl final : public MatchService::Service &#123;
    grpc::Status RequestMatch(grpc::ServerContext* ctx,
        const MatchRequest* req, MatchResponse* resp) override &#123;
        // 匹配逻辑：根据段位+地区找房间
        std::string room = findRoom(req->rank(), req->region());
        resp->set_room_id(room);
        resp->set_server_addr("10.0.1." + room);
        return grpc::Status::OK;
    &#125;
&#125;;

// ========== C++ 客户端 ==========
std::string requestMatch(std::shared_ptr&lt;grpc::Channel&gt; ch,
                         const std::string&amp; pid, int rank) &#123;
    auto stub = MatchService::NewStub(ch);
    MatchRequest req;
    req.set_player_id(pid);
    req.set_rank(rank);
    req.set_region("cn");
    MatchResponse resp;
    grpc::ClientContext ctx;
    auto st = stub->RequestMatch(&amp;ctx, req, &amp;resp);
    if (st.ok()) return resp.room_id();
    return "";  // 匹配失败
&#125;</code></pre>`}
  py={`<pre><code># ========== Python 服务端（grpcio） ==========
import grpc
from concurrent import futures
import game_pb2, game_pb2_grpc

class MatchServiceServicer(game_pb2_grpc.MatchServiceServicer):
    def RequestMatch(self, request, context):
        # 匹配逻辑：根据段位+地区找房间
        room = find_room(request.rank, request.region)
        return game_pb2.MatchResponse(
            room_id=room,
            server_addr=f"10.0.1.{room}",
            teammates=["p2", "p3", "p4"],
        )

    def GetLeaderboard(self, request, context):
        # 服务端流：逐条推送 Top100
        for rank, (pid, score) in enumerate(fetch_top100(), 1):
            yield game_pb2.ScoreEntry(player_id=pid, score=score, rank=rank)

def serve():
    server = grpc.server(futures.ThreadPoolExecutor(max_workers=10))
    game_pb2_grpc.add_MatchServiceServicer_to_server(
        MatchServiceServicer(), server)
    server.add_insecure_port("[::]:50051")
    server.start()
    server.wait_for_termination()

# ========== Python 客户端 ==========
def request_match(channel, player_id, rank):
    stub = game_pb2_grpc.MatchServiceStub(channel)
    req = game_pb2.MatchRequest(
        player_id=player_id, rank=rank, region="cn")
    resp = stub.RequestMatch(req)
    return resp.room_id</code></pre>`}
      />
