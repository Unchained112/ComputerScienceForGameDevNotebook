---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Bilingual from '../../components/Bilingual.astro';
import CodeTabs from '../../components/CodeTabs.astro';
---
<BaseLayout title="Hash Tables · CS Notebook">
  <article class="space-y-6">
    <header>
      <p class="text-sm uppercase tracking-[0.2em] text-primary-cyan mb-2">Data Structures / Hash Tables</p>
      <h1 class="text-3xl font-bold mb-2">
        <Bilingual><span slot="zh">哈希表</span><span slot="en">Hash Tables</span></Bilingual>
      </h1>
      <p class="text-ink-muted leading-relaxed">
        <Bilingual>
          <span slot="zh">哈希表用哈希函数把 key 映射到桶，平均 O(1) 查/插/删。冲突不可避免，两种主流解法：<b class="text-primary-cyan">链地址法</b>（每桶挂链表）与 <b class="text-primary-purple">开放寻址法</b>（冲突后探查下一个空位）。下方演示冲突与<b class="text-func-amber">负载因子</b>的影响。</span>
          <span slot="en">A hash table maps keys to buckets via a hash function for avg O(1) lookup/insert/delete. Collisions are inevitable; two main strategies: <b class="text-primary-cyan">chaining</b> (a list per bucket) and <b class="text-primary-purple">open addressing</b> (probe for the next free slot). Watch collisions and the <b class="text-func-amber">load factor</b> below.</span>
        </Bilingual>
      </p>
    </header>

    <section class="glass p-5" data-viz="hash">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <input id="ht-key" type="number" placeholder="key" class="btn !py-2 font-mono w-28" />
        <button id="ht-insert" class="btn btn-primary">
          <span data-ui="insert" data-lang="zh">插入</span><span data-ui="insert" data-lang="en">Insert</span>
        </button>
        <button id="ht-random" class="btn">
          <span data-ui="random" data-lang="zh">随机×8</span><span data-ui="random" data-lang="en">Random×8</span>
        </button>
        <button id="ht-reset" class="btn">
          <span data-ui="reset" data-lang="zh">重置</span><span data-ui="reset" data-lang="en">Reset</span>
        </button>
        <label class="flex items-center gap-2 text-sm text-ink-muted ml-auto">
          <span data-ui="sizelbl" data-lang="zh">表长</span><span data-ui="sizelbl" data-lang="en">Size</span>
          <input id="ht-size" type="range" min="5" max="13" value="7" class="accent-primary-cyan" />
          <b id="ht-sizeval" class="text-primary-cyan font-mono w-5">7</b>
        </label>
      </div>

      <div class="flex flex-wrap items-center gap-3 mb-4 text-sm">
        <span class="text-ink-muted">
          <span data-ui="modelbl" data-lang="zh">模式</span><span data-ui="modelbl" data-lang="en">Mode</span>:
        </span>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="radio" name="ht-mode" value="chain" checked class="accent-primary-cyan" />
          <span data-ui="chain" data-lang="zh">链地址</span><span data-ui="chain" data-lang="en">Chaining</span>
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="radio" name="ht-mode" value="open" class="accent-primary-cyan" />
          <span data-ui="open" data-lang="zh">开放寻址（线性探测）</span><span data-ui="open" data-lang="en">Open addressing (linear probe)</span>
        </label>
        <span class="ml-auto font-mono text-xs text-ink-muted">
          <span data-ui="countlbl" data-lang="zh">元素</span><span data-ui="countlbl" data-lang="en">items</span>:
          <b id="ht-count" class="text-primary-cyan">0</b>
          · α: <b id="ht-load" class="text-func-amber">0.00</b>
          · <span data-ui="colllbl" data-lang="zh">冲突</span><span data-ui="colllbl" data-lang="en">collisions</span>:
          <b id="ht-coll" class="text-func-red">0</b>
        </span>
      </div>

      <p class="text-xs text-ink-muted mb-2 font-mono">hash(key) = ((key % M) + M) % M</p>
      <div id="ht-buckets"></div>
      <p class="text-xs text-ink-muted mt-3">
        <Bilingual>
          <span slot="zh"><b class="text-primary-cyan">青=桶/首槽</b> · <b class="text-func-amber">黄=冲突链/探测</b> · <b class="text-func-green">绿=刚插入</b> · α=负载因子=元素数/表长</span>
          <span slot="en"><b class="text-primary-cyan">cyan=bucket/first slot</b> · <b class="text-func-amber">amber=collision chain/probe</b> · <b class="text-func-green">green=just inserted</b> · α = load factor = items / size</span>
        </Bilingual>
      </p>
    </section>

    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">链地址法 vs 开放寻址法</span><span slot="en">Chaining vs Open Addressing</span></Bilingual></h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="text-ink-muted text-left">
            <tr class="border-b border-[color:var(--glass-border)]">
              <th class="py-2 pr-4"></th>
              <th class="py-2 pr-4 text-primary-cyan">Chaining</th>
              <th class="py-2 pr-4 text-primary-purple">Open Addressing</th>
            </tr>
          </thead>
          <tbody class="text-ink">
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-ink-muted">冲突处理</td><td class="py-2 pr-4">桶挂链表/红黑树</td><td class="py-2 pr-4">顺次探查空位</td></tr>
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-ink-muted">负载因子 α</td><td class="py-2 pr-4">可 &gt; 1</td><td class="py-2 pr-4">须 &lt; 1（常 ≤ 0.75）</td></tr>
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-ink-muted">删除</td><td class="py-2 pr-4 text-func-green">直接删节点</td><td class="py-2 pr-4 text-func-amber">需懒删除标记</td></tr>
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-ink-muted">缓存友好</td><td class="py-2 pr-4 text-func-amber">较差（指针跳转）</td><td class="py-2 pr-4 text-func-green">好（连续内存）</td></tr>
            <tr><td class="py-2 pr-4 text-ink-muted">代表实现</td><td class="py-2 pr-4">Java HashMap, C++ unordered_map</td><td class="py-2 pr-4">Python dict, Lua table</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="grid lg:grid-cols-2 gap-4">
      <div class="glass p-5">
        <h2 class="font-semibold mb-2"><Bilingual><span slot="zh">哈希函数与插入</span><span slot="en">Hash function & insert</span></Bilingual></h2>
        <CodeTabs
  cpp={`<pre><code>// 除留余数法
int hash(int key, int M) &#123; return ((key % M) + M) % M; &#125;

// 开放寻址（线性探测）插入
bool insert(int table[], bool used[], int M, int key) &#123;
    int start = hash(key, M);
    for (int step = 0; step &lt; M; step++) &#123;
        int idx = (start + step) % M;       // 线性探测
        if (!used[idx]) &#123;
            table[idx] = key; used[idx] = true;
            return true;
        &#125;
    &#125;
    return false;                            // 表满
&#125;</code></pre>`}
  py={`<pre><code># 除留余数法
def hashing(key: int, M: int) -> int:
    return key % M

# 开放寻址（线性探测）插入
def insert(table, used, M, key):
    start = hashing(key, M)
    for step in range(M):
        idx = (start + step) % M       # 线性探测
        if not used[idx]:
            table[idx] = key
            used[idx] = True
            return True
    return False                       # 表满</code></pre>`}
        />
      </div>
      <div class="glass p-5">
        <h2 class="font-semibold mb-2"><Bilingual><span slot="zh">负载因子与 rehash</span><span slot="en">Load factor & rehash</span></Bilingual></h2>
        <p class="text-sm text-ink-muted leading-relaxed">
          <Bilingual>
            <span slot="zh">负载因子 α = 元素数 / 表长。α 越大冲突越频繁，查找越慢。当 α 超过阈值（链地址常 0.75，开放寻址常 0.5~0.7）时触发 <b class="text-func-amber">rehash</b>：扩容到约 2 倍并重新分布所有 key。</span>
            <span slot="en">Load factor α = items / size. Higher α means more collisions and slower lookups. When α crosses a threshold (≈0.75 chaining, 0.5–0.7 open addressing), a <b class="text-func-amber">rehash</b> doubles the table and redistributes all keys.</span>
          </Bilingual>
        </p>
        <ul class="text-sm text-ink-muted mt-3 space-y-1 list-disc list-inside">
          <li><Bilingual><span slot="zh">平均查/插/删：<b class="text-func-green">O(1)</b>；最坏 <b class="text-func-red">O(n)</b>（全部冲突）</span><span slot="en">avg lookup/insert/delete <b class="text-func-green">O(1)</b>; worst <b class="text-func-red">O(n)</b></span></Bilingual></li>
          <li><Bilingual><span slot="zh">游戏用途：资源句柄表、实体 ID→组件 映射、去重缓存</span><span slot="en">in games: asset handle tables, entity ID→component maps, dedup caches</span></Bilingual></li>
        </ul>
      </div>
    </section>
  </article>
</BaseLayout>

<script>
  // 哈希表冲突可视化
  type Mode = 'chain' | 'open';
  const bucketsEl = document.getElementById('ht-buckets') as HTMLElement;
  const keyInput = document.getElementById('ht-key') as HTMLInputElement;
  const sizeInput = document.getElementById('ht-size') as HTMLInputElement;
  const sizeVal = document.getElementById('ht-sizeval') as HTMLElement;
  const countEl = document.getElementById('ht-count') as HTMLElement;
  const loadEl = document.getElementById('ht-load') as HTMLElement;
  const collEl = document.getElementById('ht-coll') as HTMLElement;

  let size = 7;
  let mode: Mode = 'chain';
  let chain: number[][] = [];      // chaining: list of keys per bucket
  let openTable: (number | null)[]; // open addressing slots
  let count = 0;
  let collisions = 0;
  let lastInserted: { bucket: number; slot: number } | null = null;

  function resetState() {
    chain = Array.from({ length: size }, () => []);
    openTable = Array.from({ length: size }, () => null);
    count = 0; collisions = 0; lastInserted = null;
  }

  function h(key: number): number { return ((key % size) + size) % size; }

  function insertKey(key: number) {
    if (mode === 'chain') {
      const b = h(key);
      if (chain[b].length > 0) collisions++;
      if (!chain[b].includes(key)) { chain[b].push(key); count++; lastInserted = { bucket: b, slot: chain[b].length - 1 }; }
    } else {
      const start = h(key);
      let placed = false;
      for (let step = 0; step < size; step++) {
        const idx = (start + step) % size;
        if (openTable[idx] === null) {
          openTable[idx] = key; count++;
          if (step > 0) collisions++;
          lastInserted = { bucket: idx, slot: 0 };
          placed = true; break;
        }
        if (openTable[idx] === key) { placed = true; break; } // 已存在
      }
      if (!placed) {
        // 表满，跳过
      }
    }
    render();
  }

  function render() {
    bucketsEl.innerHTML = '';
    countEl.textContent = String(count);
    loadEl.textContent = (count / size).toFixed(2);
    collEl.textContent = String(collisions);

    if (mode === 'chain') {
      for (let b = 0; b < size; b++) {
        const row = document.createElement('div');
        row.className = 'flex items-center gap-2 mb-1.5';
        const label = document.createElement('div');
        label.className = 'w-10 text-right font-mono text-xs text-ink-muted';
        label.textContent = `[${b}]`;
        row.appendChild(label);
        const arr = document.createElement('div');
        arr.className = 'flex flex-wrap items-center gap-1.5';
        if (chain[b].length === 0) {
          arr.innerHTML = `<span class="text-ink-muted/40 font-mono">∅</span>`;
        } else {
          arr.innerHTML = `<span class="text-ink-muted font-mono">→</span>`;
          chain[b].forEach((k, i) => {
            const cell = document.createElement('div');
            let cls = 'w-12 h-9 grid place-items-center rounded-lg border font-mono text-sm ';
            const isLast = lastInserted && lastInserted.bucket === b && lastInserted.slot === i;
            if (i === 0) cls += 'border-primary-cyan/50 bg-primary-cyan/15 text-primary-cyan';
            else cls += 'border-func-amber/40 bg-func-amber/15 text-func-amber';
            if (isLast) cls += ' ring-2 ring-func-green/60';
            cell.className = cls;
            cell.textContent = String(k);
            arr.appendChild(cell);
          });
        }
        row.appendChild(arr);
        bucketsEl.appendChild(row);
      }
    } else {
      const grid = document.createElement('div');
      grid.className = 'grid gap-1.5';
      grid.style.gridTemplateColumns = 'repeat(' + size + ', minmax(0, 1fr))';
      for (let i = 0; i < size; i++) {
        const cell = document.createElement('div');
        cell.className = 'flex flex-col items-center';
        const label = document.createElement('div');
        label.className = 'text-[10px] font-mono text-ink-muted mb-1';
        label.textContent = `[${i}]`;
        const slot = document.createElement('div');
        let cls = 'w-full h-10 grid place-items-center rounded-lg border font-mono text-sm ';
        const v = openTable[i];
        const start = v !== null ? h(v) : -1;
        if (v === null) {
          cls += 'viz-cell text-ink-muted/30';
          slot.textContent = '·';
        } else {
          if (start === i) cls += 'border-primary-cyan/50 bg-primary-cyan/15 text-primary-cyan';
          else cls += 'border-func-amber/40 bg-func-amber/15 text-func-amber';
          if (lastInserted && lastInserted.bucket === i) cls += ' ring-2 ring-func-green/60';
          slot.textContent = String(v);
        }
        slot.className = cls;
        cell.appendChild(label);
        cell.appendChild(slot);
        grid.appendChild(cell);
      }
      bucketsEl.appendChild(grid);
    }
  }

  function getMode(): Mode {
    const checked = document.querySelector<HTMLInputElement>('input[name="ht-mode"]:checked');
    return checked?.value === 'open' ? 'open' : 'chain';
  }

  document.getElementById('ht-insert')?.addEventListener('click', () => {
    const v = parseInt(keyInput.value, 10);
    if (Number.isNaN(v)) return;
    insertKey(v);
    keyInput.value = '';
    keyInput.focus();
  });
  keyInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') document.getElementById('ht-insert')?.click();
  });
  document.getElementById('ht-random')?.addEventListener('click', () => {
    for (let i = 0; i < 8; i++) insertKey(Math.floor(Math.random() * 95) + 5);
  });
  document.getElementById('ht-reset')?.addEventListener('click', () => { resetState(); render(); });
  sizeInput?.addEventListener('input', () => {
    size = Number(sizeInput.value);
    sizeVal.textContent = String(size);
    resetState(); render();
  });
  document.querySelectorAll<HTMLInputElement>('input[name="ht-mode"]').forEach((r) => {
    r.addEventListener('change', () => { mode = getMode(); resetState(); render(); });
  });

  size = Number(sizeInput.value);
  mode = getMode();
  resetState();
  render();
</script>
