---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Bilingual from '../../components/Bilingual.astro';
import CodeTabs from '../../components/CodeTabs.astro';
---
<BaseLayout title="Searching · CS Notebook">
  <article class="space-y-6">
    <header>
      <p class="text-sm uppercase tracking-[0.2em] text-primary-cyan mb-2">Algorithms / Searching</p>
      <h1 class="text-3xl font-bold mb-2">
        <Bilingual><span slot="zh">二分查找</span><span slot="en">Binary Search</span></Bilingual>
      </h1>
      <p class="text-ink-muted leading-relaxed">
        <Bilingual>
          <span slot="zh">二分查找在<b>有序</b>序列上以 O(log n) 定位目标。关键是维护半开区间 <code>[lo, hi)</code>：每轮取中点 <code>mid = lo + (hi-lo)/2</code> 比较，淘汰一半。颜色含义：<b class="text-func-amber">黄=中点</b>、<b class="text-ink-muted">灰=已淘汰</b>、<b class="text-func-green">绿=命中</b>、<b class="text-func-red">红=未找到</b>。</span>
          <span slot="en">Binary search locates a target in a <b>sorted</b> sequence in O(log n). The key is maintaining a half-open range <code>[lo, hi)</code>: each step compares the midpoint <code>mid = lo + (hi-lo)/2</code> and discards half. Colors: <b class="text-func-amber">amber=mid</b>, <b class="text-ink-muted">gray=eliminated</b>, <b class="text-func-green">green=hit</b>, <b class="text-func-red">red=miss</b>.</span>
        </Bilingual>
      </p>
    </header>

    <div class="glass p-5" data-viz="binsearch">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <label class="flex items-center gap-2 text-sm text-ink-muted">
          <span data-ui="target" data-lang="zh">目标</span><span data-ui="target" data-lang="en">Target</span>
          <select id="bs-target" class="btn !py-1.5"></select>
        </label>
        <button id="bs-play" class="btn btn-primary">
          <span data-ui="play" data-lang="zh">播放</span><span data-ui="play" data-lang="en">Play</span>
          <span data-ui="pause" data-lang="zh" class="hidden">暂停</span><span data-ui="pause" data-lang="en" class="hidden">Pause</span>
        </button>
        <button id="bs-step" class="btn"><span data-ui="step" data-lang="zh">单步</span><span data-ui="step" data-lang="en">Step</span></button>
        <button id="bs-reset" class="btn"><span data-ui="reset" data-lang="zh">重置</span><span data-ui="reset" data-lang="en">Reset</span></button>
        <span id="bs-state" class="text-xs font-mono text-ink-muted"></span>
      </div>
      <svg id="bs-svg" viewBox="0 0 800 200" class="w-full h-52 viz-stage"></svg>
    </div>

    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">lower_bound / upper_bound</span><span slot="en">lower_bound / upper_bound</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh">在有序区间中找<b>第一个 ≥ target</b>（lower_bound）与<b>第一个 &gt; target</b>（upper_bound）的位置。两者都用半开区间 <code>[lo, hi)</code>，循环不变量：答案一定落在 <code>[lo, hi)</code> 内。是 C++ STL 的基石。</span><span slot="en">Find the <b>first ≥ target</b> (lower_bound) and <b>first &gt; target</b> (upper_bound) in a sorted range. Both use a half-open range <code>[lo, hi)</code>; the loop invariant keeps the answer inside <code>[lo, hi)</code>. Foundation of the C++ STL.</span></Bilingual></p>
      <CodeTabs
  cpp={`<pre><code>// 半开区间 [lo, hi)：第一个 &gt;= x 的位置
int lower_bound(int a[], int n, int x) &#123;
    int lo = 0, hi = n;          // 不变量：答案 ∈ [lo, hi)
    while (lo &lt; hi) &#123;
        int mid = lo + (hi - lo) / 2;
        if (a[mid] &lt; x) lo = mid + 1;
        else             hi = mid;   // a[mid] &gt;= x，mid 是候选，收缩右界
    &#125;
    return lo;                    // lo == hi
&#125;

// 半开区间 [lo, hi)：第一个 &gt; x 的位置
int upper_bound(int a[], int n, int x) &#123;
    int lo = 0, hi = n;
    while (lo &lt; hi) &#123;
        int mid = lo + (hi - lo) / 2;
        if (a[mid] &lt;= x) lo = mid + 1;
        else              hi = mid;   // a[mid] &gt; x，mid 是候选
    &#125;
    return lo;
&#125;

// 精确查找：命中返回下标，否则返回 -1
int binary_search(int a[], int n, int x) &#123;
    int i = lower_bound(a, n, x);
    return (i &lt; n &amp;&amp; a[i] == x) ? i : -1;
&#125;</code></pre>`}
  py={`<pre><code>import bisect

# 半开区间 [lo, hi)：第一个 >= x 的位置
def lower_bound(a, x):
    lo, hi = 0, len(a)         # 不变量：答案 ∈ [lo, hi)
    while lo < hi:
        mid = lo + (hi - lo) // 2
        if a[mid] < x: lo = mid + 1
        else: hi = mid          # a[mid] >= x，mid 是候选，收缩右界
    return lo                   # lo == hi

# 半开区间 [lo, hi)：第一个 > x 的位置
def upper_bound(a, x):
    lo, hi = 0, len(a)
    while lo < hi:
        mid = lo + (hi - lo) // 2
        if a[mid] <= x: lo = mid + 1
        else: hi = mid           # a[mid] > x，mid 是候选
    return lo

# 精确查找：命中返回下标，否则返回 -1
def binary_search(a, x):
    i = lower_bound(a, x)
    return i if i < len(a) and a[i] == x else -1

# 注：Python 标准库 bisect 已提供 bisect_left / bisect_right</code></pre>`}
        />
      <p class="text-xs text-ink-muted mt-3"><Bilingual><span slot="zh">用 <code>mid = lo + (hi-lo)/2</code> 而非 <code>(lo+hi)/2</code> 可避免整数溢出。等号方向决定收缩的是 <code>lo</code> 还是 <code>hi</code>，写错会死循环。</span><span slot="en">Use <code>mid = lo + (hi-lo)/2</code> (not <code>(lo+hi)/2</code>) to avoid integer overflow. The direction of the comparison decides whether <code>lo</code> or <code>hi</code> shrinks — get it wrong and you get an infinite loop.</span></Bilingual></p>
    </section>

    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">常见变体与陷阱</span><span slot="en">Variants & Pitfalls</span></Bilingual></h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="text-ink-muted text-left"><tr class="border-b border-[color:var(--glass-border)]"><th class="py-2 pr-4"><Bilingual><span slot="zh">变体</span><span slot="en">Variant</span></Bilingual></th><th class="py-2 pr-4"><Bilingual><span slot="zh">区间</span><span slot="en">Range</span></Bilingual></th><th class="py-2 pr-4"><Bilingual><span slot="zh">收缩</span><span slot="en">Shrink</span></Bilingual></th><th class="py-2 pr-4"><Bilingual><span slot="zh">终止</span><span slot="en">Stop</span></Bilingual></th></tr></thead>
          <tbody class="text-ink">
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-ink-muted">lower_bound</td><td class="py-2 pr-4">[0, n)</td><td class="py-2 pr-4">a[mid]&lt;x → lo=mid+1；否则 hi=mid</td><td class="py-2 pr-4">lo == hi</td></tr>
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-ink-muted">闭区间 [lo,hi]</td><td class="py-2 pr-4">[0, n-1]</td><td class="py-2 pr-4">a[mid]&lt;x → lo=mid+1；否则 hi=mid-1</td><td class="py-2 pr-4">lo &gt; hi</td></tr>
            <tr><td class="py-2 pr-4 text-ink-muted">浮点二分</td><td class="py-2 pr-4">[lo, hi]</td><td class="py-2 pr-4">同闭区间</td><td class="py-2 pr-4">hi-lo &lt; eps（迭代 100 次更稳）</td></tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-ink-muted mt-3"><Bilingual><span slot="zh">二分答案：当「判定」是单调的（若 x 可行则所有 ≥x 都可行），可在答案域上二分 + 贪心/模拟判定。常见于「最大化最小值」问题。</span><span slot="en">Binary search on the answer: when the predicate is monotone (if x is feasible, all ≥x are), binary search the answer space + greedy/simulate to check. Common in "maximize the minimum" problems.</span></Bilingual></p>
    </section>
  </article>
</BaseLayout>

<script>
  // 固定有序数组
  const DATA = [3, 8, 11, 17, 24, 29, 37, 42, 55, 63, 71, 88];
  const SVGNS = 'http://www.w3.org/2000/svg';
  const svg = document.getElementById('bs-svg') as unknown as SVGSVGElement;
  const sel = document.getElementById('bs-target') as HTMLSelectElement;
  const stateEl = document.getElementById('bs-state');

  const COL_DEF = '#22D3EE', COL_MID = '#FBBF24', COL_DEAD = '#475569', COL_HIT = '#22C55E', COL_MISS = '#EF4444';
  const CW = 56, STARTX = 60, Y = 110;

  interface Frame { lo: number; hi: number; mid: number; status: 'search' | 'hit' | 'miss'; }

  function buildFrames(target: number): Frame[] {
    const frames: Frame[] = [];
    let lo = 0, hi = DATA.length;
    while (lo < hi) {
      const mid = lo + ((hi - lo) >> 1);
      frames.push({ lo, hi, mid, status: 'search' });
      if (DATA[mid] < target) lo = mid + 1;
      else if (DATA[mid] > target) hi = mid;
      else { frames.push({ lo, hi, mid, status: 'hit' }); return frames; }
    }
    frames.push({ lo, hi, mid: -1, status: 'miss' });
    return frames;
  }

  function langText(key: string): string {
    const lang = document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh';
    const el = document.querySelector(`[data-ui="${key}"][data-lang="${lang}"]`);
    return el ? el.textContent || '' : '';
  }

  function render(f: Frame | null) {
    svg.innerHTML = '';
    const dead = new Set<number>();
    if (f) {
      if (f.status === 'hit') dead = new Set();
      else { for (let i = 0; i < DATA.length; i++) if (i < f.lo || i >= f.hi) dead.add(i); }
    }
    // 指针线
    function ptr(idx: number, label: string, color: string, dy: number) {
      const x = STARTX + idx * CW + CW / 2;
      const l = document.createElementNS(SVGNS, 'text');
      l.setAttribute('x', String(x)); l.setAttribute('y', String(Y + dy));
      l.setAttribute('text-anchor', 'middle'); l.setAttribute('font-size', '12');
      l.setAttribute('fill', color); l.setAttribute('font-weight', '700');
      l.textContent = label; svg.appendChild(l);
    }
    for (let i = 0; i < DATA.length; i++) {
      const x = STARTX + i * CW;
      let fill = COL_DEF;
      if (f && f.status === 'hit' && i === f.mid) fill = COL_HIT;
      else if (f && f.status === 'miss') fill = dead.has(i) ? COL_DEAD : COL_MISS;
      else if (f && i === f.mid) fill = COL_MID;
      else if (dead.has(i)) fill = COL_DEAD;
      const r = document.createElementNS(SVGNS, 'rect');
      r.setAttribute('x', String(x)); r.setAttribute('y', String(Y - 24));
      r.setAttribute('width', String(CW - 6)); r.setAttribute('height', '48');
      r.setAttribute('rx', '6'); r.setAttribute('fill', fill); r.setAttribute('opacity', '0.9');
      svg.appendChild(r);
      const t = document.createElementNS(SVGNS, 'text');
      t.setAttribute('x', String(x + (CW - 6) / 2)); t.setAttribute('y', String(Y + 4));
      t.setAttribute('text-anchor', 'middle'); t.setAttribute('font-size', '14');
      t.setAttribute('fill', '#0B1120'); t.setAttribute('font-weight', '600');
      t.textContent = String(DATA[i]); svg.appendChild(t);
    }
    if (f && f.status !== 'miss') {
      ptr(f.lo, 'lo', '#22D3EE', 50);
      ptr(f.hi - 1, 'hi', '#A78BFA', 50);
      if (f.status === 'search') ptr(f.mid, 'mid', '#FBBF24', -38);
    }
    if (stateEl) {
      if (!f) stateEl.textContent = '';
      else if (f.status === 'hit') {
        const lang = document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh';
        stateEl.textContent = lang === 'en' ? `found at index ${f.mid}` : `命中下标 ${f.mid}`;
      } else if (f.status === 'miss') {
        const lang = document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh';
        stateEl.textContent = lang === 'en' ? 'not found' : '未找到';
      } else {
        const cur = DATA[f.mid];
        const cmp = cur < Number(sel.value) ? '<' : '>';
        stateEl.textContent = `a[mid]=${cur} ${cmp} ${sel.value}`;
      }
    }
  }

  let frames: Frame[] = [];
  let idx = 0;
  let timer: number | null = null;

  function stop() {
    if (timer !== null) { clearInterval(timer); timer = null; }
    const b = document.getElementById('bs-play');
    if (b) b.innerHTML = langText('play');
  }
  function rebuild() {
    stop();
    frames = buildFrames(Number(sel.value));
    idx = 0;
    render(null);
    if (stateEl) stateEl.textContent = '';
  }
  function advance(): boolean {
    if (idx < frames.length) { render(frames[idx]); idx++; return true; }
    return false;
  }
  function play() {
    if (timer !== null) { stop(); return; }
    const b = document.getElementById('bs-play');
    if (b) b.innerHTML = langText('pause');
    timer = window.setInterval(() => { if (!advance()) stop(); }, 700);
  }

  // 填充目标下拉
  for (const v of DATA) {
    const o = document.createElement('option');
    o.value = String(v); o.textContent = String(v);
    sel.appendChild(o);
  }
  sel.value = String(DATA[5]);
  document.getElementById('bs-play')?.addEventListener('click', play);
  document.getElementById('bs-step')?.addEventListener('click', () => { stop(); advance(); });
  document.getElementById('bs-reset')?.addEventListener('click', rebuild);
  sel?.addEventListener('change', rebuild);
  document.addEventListener('langchange', () => { if (timer === null) { const b = document.getElementById('bs-play'); if (b) b.innerHTML = langText('play'); if (idx > 0) render(frames[idx - 1]); } });
  rebuild();
</script>
