    card.setAttribute('width', String(cardW)); card.setAttribute('height', String(cardH));
    card.setAttribute('rx', '10'); card.setAttribute('fill', data.color + '11');
    card.setAttribute('stroke', data.color + '66'); card.setAttribute('stroke-width', '1.5');
    svg.appendChild(card);

    // 卡片标题
    const title = document.createElementNS(SVGNS, 'text');
    title.setAttribute('x', String(cardX + 20)); title.setAttribute('y', String(cardY + 28));
    title.setAttribute('font-size', '16'); title.setAttribute('font-weight', '700');
    title.setAttribute('fill', data.color);
    title.textContent = `C++${std} (${data.year}) — ${lang() === 'en' ? data.nicknameEn : data.nicknameZh}`;
    svg.appendChild(title);

    // 特性列表（两列）
    const feats = data.features;
    const colCount = 2;
    const rowH = 18;
    const startY = cardY + 52;
    for (let i = 0; i < feats.length && i < 12; i++) {
      const col = i % colCount;
      const row = Math.floor(i / colCount);
      const fx = cardX + 20 + col * 360;
      const fy = startY + row * rowH;
      if (fy > cardY + cardH - 10) break;

      // bullet
      const bullet = document.createElementNS(SVGNS, 'circle');
      bullet.setAttribute('cx', String(fx)); bullet.setAttribute('cy', String(fy - 4));
      bullet.setAttribute('r', '2.5'); bullet.setAttribute('fill', data.color);
      svg.appendChild(bullet);

      const t = document.createElementNS(SVGNS, 'text');
      t.setAttribute('x', String(fx + 10)); t.setAttribute('y', String(fy));
      t.setAttribute('font-size', '12'); t.setAttribute('fill', '#CBD5E1');
      t.textContent = lang() === 'en' ? feats[i].en : feats[i].zh;
      svg.appendChild(t);
    }
  }

  function setActive(std: string) {
    stdButtons.forEach(b => {
      b.classList.toggle('btn-primary', b.dataset.std === std);
    });
    render(std);
  }

  stdButtons.forEach(b => b.addEventListener('click', () => setActive(b.dataset.std!)));
  document.addEventListener('langchange', () => {
    const active = document.querySelector<HTMLButtonElement>('.std-btn.btn-primary');
    render(active?.dataset.std || '11');
  });
  setActive('11');
</script>
