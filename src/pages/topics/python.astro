    <!-- 解释型执行模型 -->
    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">解释型执行模型</span><span slot="en">Interpreted Execution Model</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh">Python 常被笼统称为"解释型语言"，但它并非逐行解释源码。CPython 的执行是一条<b>两段式流水线</b>：源码（<code>.py</code>）先被<b>编译</b>为字节码（<code>.pyc</code> 缓存），再由<b>栈式虚拟机</b>逐条解释执行。这套模型介于 C++ 的 AOT（直接编译为机器码）和 JVM/V8 的 JIT（运行时编译热点）之间——Python 没有 JIT，每条字节码都经过 VM 大循环分发，这是它慢的结构性原因，但也带来了启动快、跨平台、易调试的优势。</span><span slot="en">Python is loosely called "interpreted", but it doesn't interpret source line-by-line. CPython runs a <b>two-stage pipeline</b>: source (<code>.py</code>) is first <b>compiled</b> to bytecode (cached as <code>.pyc</code>), then executed by a <b>stack-based VM</b> instruction by instruction. This model sits between C++'s AOT (direct to machine code) and JVM/V8's JIT (runtime hotspot compilation) — Python has no JIT; each bytecode goes through the VM dispatch loop, a structural cause of slowness, but it also brings fast startup, portability, and easy debugging.</span></Bilingual></p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="text-ink-muted text-left"><tr class="border-b border-[color:var(--glass-border)]"><th class="py-2 pr-4"><Bilingual><span slot="zh">模型</span><span slot="en">Model</span></Bilingual></th><th class="py-2 pr-4"><Bilingual><span slot="zh">代表</span><span slot="en">Example</span></Bilingual></th><th class="py-2 pr-4"><Bilingual><span slot="zh">编译产物</span><span slot="en">Output</span></Bilingual></th><th class="py-2 pr-4"><Bilingual><span slot="zh">运行机制</span><span slot="en">Runtime</span></Bilingual></th></tr></thead>
          <tbody class="text-ink">
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-func-green">AOT</td><td class="py-2 pr-4">C / C++ / Rust</td><td class="py-2 pr-4 font-mono">机器码 (.exe)</td><td class="py-2 pr-4"><Bilingual><span slot="zh">CPU 直接执行</span><span slot="en">CPU executes directly</span></Bilingual></td></tr>
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-primary-cyan">字节码解释</td><td class="py-2 pr-4">CPython</td><td class="py-2 pr-4 font-mono">字节码 (.pyc)</td><td class="py-2 pr-4"><Bilingual><span slot="zh">VM 大循环解释</span><span slot="en">VM dispatch loop</span></Bilingual></td></tr>
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-primary-purple">JIT</td><td class="py-2 pr-4">PyPy / V8 / JVM</td><td class="py-2 pr-4 font-mono">机器码 (运行时)</td><td class="py-2 pr-4"><Bilingual><span slot="zh">热点编译后执行</span><span slot="en">Hotspot compile then run</span></Bilingual></td></tr>
            <tr><td class="py-2 pr-4 text-func-amber">混合</td><td class="py-2 pr-4">.NET / Dalvik</td><td class="py-2 pr-4 font-mono">字节码 + JIT</td><td class="py-2 pr-4"><Bilingual><span slot="zh">解释 + 热点编译</span><span slot="en">Interpret + hotspot compile</span></Bilingual></td></tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-ink-muted mt-3"><Bilingual><span slot="zh">深入原理：<a class="text-primary-cyan underline" href="/topics/py-vm">虚拟机与字节码</a>详解 ceval.c 大循环与 Code Object 结构。</span><span slot="en">Deep dive: <a class="text-primary-cyan underline" href="/topics/py-vm">VM & Bytecode</a> for ceval.c loop & Code Object internals.</span></Bilingual></p>
    </section>

    <!-- Python vs C++ -->
    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">Python vs C++：性能与生态取舍</span><span slot="en">Python vs C++: Performance & Ecosystem Trade-off</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh">游戏开发中 Python 与 C++ 不是竞争关系，而是<b>分层协作</b>：C++ 负责性能敏感的引擎核心（渲染、物理、内存），Python 负责迭代速度敏感的工具链与脚本。理解两者在每个维度的差距，才能正确选型——不要用 Python 写渲染管线，也不要用 C++ 写配置解析脚本。</span><span slot="en">In game dev, Python and C++ aren't competitors but <b>layered collaborators</b>: C++ handles performance-critical engine cores (rendering, physics, memory); Python handles iteration-speed-critical tooling and scripting. Understanding the gap on each axis enables correct choices — don't write a render pipeline in Python, nor a config parser in C++.</span></Bilingual></p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="text-ink-muted text-left"><tr class="border-b border-[color:var(--glass-border)]"><th class="py-2 pr-4"><Bilingual><span slot="zh">维度</span><span slot="en">Dimension</span></Bilingual></th><th class="py-2 pr-4 text-primary-cyan">Python</th><th class="py-2 pr-4 text-func-amber">C++</th></tr></thead>
          <tbody class="text-ink">
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-ink-muted"><Bilingual><span slot="zh">类型系统</span><span slot="en">Typing</span></Bilingual></td><td class="py-2 pr-4"><Bilingual><span slot="zh">动态（运行时检查）</span><span slot="en">Dynamic (runtime)</span></Bilingual></td><td class="py-2 pr-4"><Bilingual><span slot="zh">静态（编译期检查）</span><span slot="en">Static (compile-time)</span></Bilingual></td></tr>
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-ink-muted"><Bilingual><span slot="zh">执行方式</span><span slot="en">Execution</span></Bilingual></td><td class="py-2 pr-4"><Bilingual><span slot="zh">字节码解释</span><span slot="en">Bytecode interpreted</span></Bilingual></td><td class="py-2 pr-4"><Bilingual><span slot="zh">AOT 编译为机器码</span><span slot="en">AOT to machine code</span></Bilingual></td></tr>
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-ink-muted"><Bilingual><span slot="zh">内存管理</span><span slot="en">Memory</span></Bilingual></td><td class="py-2 pr-4"><Bilingual><span slot="zh">GC（引用计数 + 分代）</span><span slot="en">GC (refcount + generational)</span></Bilingual></td><td class="py-2 pr-4"><Bilingual><span slot="zh">手动 / RAII / 智能指针</span><span slot="en">Manual / RAII / smart ptr</span></Bilingual></td></tr>
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-ink-muted"><Bilingual><span slot="zh">性能</span><span slot="en">Performance</span></Bilingual></td><td class="py-2 pr-4 text-func-red"><Bilingual><span slot="zh">慢（C++ 的 1/30~1/100）</span><span slot="en">Slow (1/30~1/100 of C++)</span></Bilingual></td><td class="py-2 pr-4 text-func-green"><Bilingual><span slot="zh">快（基准）</span><span slot="en">Fast (baseline)</span></Bilingual></td></tr>
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-ink-muted"><Bilingual><span slot="zh">迭代速度</span><span slot="en">Iteration</span></Bilingual></td><td class="py-2 pr-4 text-func-green"><Bilingual><span slot="zh">极快（无编译，改完即跑）</span><span slot="en">Instant (no compile)</span></Bilingual></td><td class="py-2 pr-4 text-func-red"><Bilingual><span slot="zh">慢（编译耗时长）</span><span slot="en">Slow (long compile)</span></Bilingual></td></tr>
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-ink-muted"><Bilingual><span slot="zh">并发</span><span slot="en">Concurrency</span></Bilingual></td><td class="py-2 pr-4"><Bilingual><span slot="zh">GIL 限制（多进程绕行）</span><span slot="en">GIL-limited (multiprocess)</span></Bilingual></td><td class="py-2 pr-4"><Bilingual><span slot="zh">原生多线程</span><span slot="en">Native multithreading</span></Bilingual></td></tr>
            <tr><td class="py-2 pr-4 text-ink-muted"><Bilingual><span slot="zh">游戏角色</span><span slot="en">Game role</span></Bilingual></td><td class="py-2 pr-4"><Bilingual><span slot="zh">工具链 / 脚本 / AI / 服务端</span><span slot="en">Tooling / script / AI / server</span></Bilingual></td><td class="py-2 pr-4"><Bilingual><span slot="zh">引擎核心 / 渲染 / 物理</span><span slot="en">Engine core / render / physics</span></Bilingual></td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- GIL 原理 -->
    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">GIL：全局解释器锁</span><span slot="en">GIL: Global Interpreter Lock</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh">GIL 是 CPython 最具争议的设计——一个进程级互斥锁，确保任一时刻<b>只有一个线程</b>执行字节码。它存在的根本原因是保护<b>引用计数</b>的线程安全：CPython 的内存回收依赖 <code>ob_refcnt</code>，若多线程同时增减计数会引发竞态导致提前释放或泄漏。加细粒度锁到每个对象开销太大，GIL 是"一把大锁保平安"的工程妥协。<b>GIL 使多线程无法利用多核做 CPU 密集计算</b>，但 I/O 操作（网络/文件/sleep）会主动释放 GIL，因此多线程对 I/O 密集任务仍有效。绕开 GIL 的标准方案是 <code>multiprocessing</code>——每进程独立 GIL，真并行，但代价是进程间数据需序列化（pickle）传输。</span><span slot="en">The GIL is CPython's most controversial design — a process-wide mutex ensuring only <b>one thread</b> executes bytecode at a time. It exists fundamentally to protect <b>reference counting</b> thread-safety: CPython's reclamation relies on <code>ob_refcnt</code>; concurrent inc/dec would cause races leading to premature frees or leaks. Fine-grained per-object locks are too costly, so the GIL is an engineering compromise of "one big lock for peace of mind". <b>The GIL prevents multithreaded CPU-bound parallelism</b>, but I/O ops (network/file/sleep) proactively release it, so threading still helps I/O-bound workloads. The standard workaround is <code>multiprocessing</code> — each process has its own GIL, enabling true parallelism, at the cost of serializing (pickling) data between processes.</span></Bilingual></p>
      <pre class="glass p-4 overflow-x-auto text-sm"><code><span class="text-func-red"># CPU 密集：多线程无并行收益（GIL 串行化）</span>
<span class="text-ink-muted"># import threading</span>
<span class="text-ink-muted"># def cpu_work(n):</span>
<span class="text-ink-muted">#     while n > 0: n -= 1   # 纯 Python 计算，持有 GIL</span>
<span class="text-ink-muted"># 两个线程跑 cpu_work(10**8) 总耗时 ≈ 单线程两倍 —— 无加速</span>

<span class="text-func-green"># I/O 密集：多线程有效（I/O 时释放 GIL）</span>
import threading, time, urllib.request
def fetch(url):
    urllib.request.urlopen(url)  <span class="text-ink-muted"># 网络 I/O，释放 GIL</span>
t0 = time.time()
threads = [threading.Thread(target=fetch, args=(url,)) for url in urls]
for t in threads: t.start()
for t in threads: t.join()       <span class="text-func-amber"># 并发完成，总耗时 ≈ 最慢的一个请求</span>

<span class="text-primary-cyan"># 绕 GIL 做 CPU 并行：multiprocessing（每进程独立 GIL）</span>
from multiprocessing import Pool
def cpu_work(n):
    while n > 0: n -= 1
with Pool(8) as p:               <span class="text-func-amber"># 真·8核并行</span>
    p.map(cpu_work, [10**8]*8)
<span class="text-ink-muted"># 代价：进程间内存不共享，参数/结果需 pickle 序列化</span>

<span class="text-primary-purple"># PEP 703 (3.13 实验性): free-threading，移除 GIL</span>
<span class="text-ink-muted"># 需 --disable-gil 编译的 python3.13t，多线程可真并行做 CPU 计算</span></code></pre>
      <p class="text-xs text-ink-muted mt-3"><Bilingual><span slot="zh">深入：<a class="text-primary-cyan underline" href="/topics/py-objects">对象模型</a>讲解引用计数为何需要 GIL 保护；<a class="text-primary-cyan underline" href="/topics/py-optimization">性能优化</a>讲解 CPU 密集任务的优化路径。</span><span slot="en">Deep dive: <a class="text-primary-cyan underline" href="/topics/py-objects">Object Model</a> for why refcounting needs the GIL; <a class="text-primary-cyan underline" href="/topics/py-optimization">Performance</a> for CPU-bound optimization paths.</span></Bilingual></p>
    </section>

    <!-- Python 生态与游戏开发定位 -->
    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">Python 生态与游戏开发定位</span><span slot="en">Python Ecosystem & Game Dev Role</span></Bilingual></h2>
      <p class="text-sm text-ink-muted leading-relaxed">
        <Bilingual>
          <span slot="zh">Python 在游戏项目中几乎不出现在运行时性能路径，而是<b>无处不在地出现在工具链</b>。它的价值在于"胶水"——快速串联各环节，用最短代码完成一次性任务：<br>
          • <b class="text-func-amber">工具链</b>：资源导入管线（FBX→引擎格式）、构建脚本、CI/CD、自动化测试。Maya/Blender/Houdini 的脚本 API 都是 Python。<br>
          • <b class="text-primary-cyan">配置与数据</b>：JSON/YAML/TOML 读写、Excel 配置导表、数据校验（pydantic）。策划配表到运行时数据的转换几乎都用 Python。<br>
          • <b class="text-func-green">AI / 数据分析</b>：训练模型（PyTorch）、玩家行为挖掘、A/B 测试、数值平衡仿真。<br>
          • <b class="text-primary-purple">服务端脚本</b>：Panda3D / BigWorld 架构用 Python 写游戏逻辑（热更新友好），国内不少 MMO 服务端业务层用 Python。</span>
          <span slot="en">Python almost never appears on the runtime performance path in game projects, but is <b>ubiquitous in the toolchain</b>. Its value is "glue" — quickly connecting pipeline stages, doing one-off tasks in minimal code:<br>
          • <b class="text-func-amber">Tooling</b>: asset import (FBX→engine format), build scripts, CI/CD, automated tests. Maya/Blender/Houdini scripting APIs are all Python.<br>
          • <b class="text-primary-cyan">Config & data</b>: JSON/YAML/TOML I/O, Excel config export, data validation (pydantic). Designer tables → runtime data conversion is almost always Python.<br>
          • <b class="text-func-green">AI / analytics</b>: model training (PyTorch), player behavior mining, A/B testing, balance simulation.<br>
          • <b class="text-primary-purple">Server scripts</b>: Panda3D / BigWorld architectures write game logic in Python (hot-reload friendly); many Chinese MMO servers use Python for business logic.</span>
        </Bilingual>
      </p>
    </section>

    <!-- Python 演进与未来（前沿补充） -->
    <section class="glass p-5">
      <h2 class="font-semibold mb-3"><Bilingual><span slot="zh">Python 演进与未来</span><span slot="en">Python Evolution & Future</span></Bilingual></h2>
      <p class="text-sm text-ink-muted mb-3"><Bilingual><span slot="zh">CPython 并非停滞不前。3.11 起的 <b>"Faster CPython" 项目</b>正在系统性消除前述性能瓶颈，三个里程碑值得游戏开发者关注——它们直接关系到"Python 还能不能更快、能不能并行"。</span><span slot="en">CPython isn't standing still. Since 3.11, the <b>"Faster CPython" project</b> has been systematically eliminating the aforementioned performance bottlenecks. Three milestones matter to game developers — they directly address "can Python be faster, can it parallelize".</span></Bilingual></p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="text-ink-muted text-left"><tr class="border-b border-[color:var(--glass-border)]"><th class="py-2 pr-4"><Bilingual><span slot="zh">版本</span><span slot="en">Version</span></Bilingual></th><th class="py-2 pr-4"><Bilingual><span slot="zh">特性</span><span slot="en">Feature</span></Bilingual></th><th class="py-2 pr-4"><Bilingual><span slot="zh">说明</span><span slot="en">Description</span></Bilingual></th></tr></thead>
          <tbody class="text-ink">
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-func-green font-mono">3.11</td><td class="py-2 pr-4 text-primary-cyan">Specializing Interpreter<br/><span class="text-xs text-ink-muted">PEP 659</span></td><td class="py-2 pr-4"><Bilingual><span slot="zh"><b>自适应指令</b>：运行时把热点 <code>LOAD_FAST</code>/<code>BINARY_OP</code> 替换为专用版本（如 <code>LOAD_FAST_BORROW</code>、<code>BINARY_OP_ADD_INT</code>），减少类型分发开销。比 3.10 快 <b>10-60%</b>。这是"在不引入 JIT 的前提下压榨解释器"的精妙设计。</span><span slot="en"><b>Adaptive instructions</b>: at runtime replaces hot <code>LOAD_FAST</code>/<code>BINARY_OP</code> with specialized variants (e.g. <code>LOAD_FAST_BORROW</code>, <code>BINARY_OP_ADD_INT</code>), reducing type-dispatch overhead. 10-60% faster than 3.10. A brilliant design that "squeezes the interpreter without introducing JIT".</span></Bilingual></td></tr>
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-func-green font-mono">3.12</td><td class="py-2 pr-4 text-primary-purple">Immortal Objects<br/><span class="text-xs text-ink-muted">PEP 683</span></td><td class="py-2 pr-4"><Bilingual><span slot="zh"><b>永生对象</b>：引用计数设为特殊值（永不过零），<code>Py_INCREF</code>/<code>Py_DECREF</code> 对它们变为无操作。解决多进程 <code>fork</code> 后<b>写时复制（COW）页因引用计数写而失效</b>的问题——此前子进程一碰对象就触发 COW 拷贝，内存翻倍。对 <code>multiprocessing</code> 密集的游戏工具链是实打实的内存优化。</span><span slot="en"><b>Immortal objects</b>: refcount set to a special value (never hits zero); <code>Py_INCREF</code>/<code>Py_DECREF</code> become no-ops for them. Fixes the issue where <code>fork</code>ed child processes trigger <b>copy-on-write (COW) page faults</b> merely by touching refcounts — previously doubling memory. A tangible memory win for <code>multiprocessing</code>-heavy game toolchains.</span></Bilingual></td></tr>
            <tr class="border-b border-[color:var(--glass-border)]"><td class="py-2 pr-4 text-func-green font-mono">3.13</td><td class="py-2 pr-4 text-func-amber">Free-threading<br/><span class="text-xs text-ink-muted">PEP 703</span></td><td class="py-2 pr-4"><Bilingual><span slot="zh"><b>自由线程（no-GIL）</b>：实验性可选移除 GIL，多线程可<b>真并行</b>做 CPU 计算。需用 <code>--disable-gil</code> 编译的 <code>python3.13t</code>。代价是单线程略慢（去掉 GIL 后每对象需细粒度锁/无锁引用计数）。这是 Python 并行计算的重大方向，但生态兼容仍需时间。</span><span slot="en"><b>Free-threading (no-GIL)</b>: experimental optional GIL removal, enabling true multithreaded CPU parallelism. Requires a <code>--disable-gil</code> build (<code>python3.13t</code>). Cost: single-threaded slightly slower (per-object fine-grained/lockless refcounting). A major direction for Python parallelism, though ecosystem compatibility needs time.</span></Bilingual></td></tr>
            <tr><td class="py-2 pr-4 text-func-green font-mono">3.13+</td><td class="py-2 pr-4 text-func-green">Copy-and-patch JIT<br/><span class="text-xs text-ink-muted">Experimental</span></td><td class="py-2 pr-4"><Bilingual><span slot="zh"><b>复制式 JIT</b>：把热点字节码的小段编译为机器码（copy-and-patch 技术），介于解释与完整 JIT 之间。3.13 为实验性，长远目标是让 CPython 接近 PyPy 的性能。与 specializing interpreter 互补——后者优化解释器本身，JIT 直接产出机器码。</span><span slot="en"><b>Copy-and-patch JIT</b>: compiles small hot bytecode segments to machine code (copy-and-patch technique), sitting between interpretation and full JIT. Experimental in 3.13; long-term goal is approaching PyPy performance. Complements the specializing interpreter — the latter optimizes the interpreter itself, JIT produces machine code directly.</span></Bilingual></td></tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-ink-muted mt-3"><Bilingual><span slot="zh">这些演进直接回应了本页前述的性能痛点：specializing interpreter 减少指令分发开销（见<a class="text-primary-cyan underline" href="/topics/py-vm">虚拟机页</a>）；immortal objects 降低多进程内存（见<a class="text-primary-cyan underline" href="/topics/py-objects">对象模型页</a>）；free-threading 打破 GIL 并行限制（见<a class="text-primary-cyan underline" href="/topics/py-optimization">性能优化页</a>）。</span><span slot="en">These evolutions directly address the pain points above: specializing interpreter cuts instruction dispatch overhead (see <a class="text-primary-cyan underline" href="/topics/py-vm">VM page</a>); immortal objects reduce multiprocess memory (see <a class="text-primary-cyan underline" href="/topics/py-objects">Object Model page</a>); free-threading breaks the GIL parallelism limit (see <a class="text-primary-cyan underline" href="/topics/py-optimization">Performance page</a>).</span></Bilingual></p>
    </section>

    <p class="text-xs text-ink-muted"><Bilingual><span slot="zh">关联阅读：<a class="text-primary-cyan underline" href="/topics/py-syntax">语法与数据结构</a> · <a class="text-primary-cyan underline" href="/topics/py-stdlib">标准库与工具链</a> · <a class="text-primary-cyan underline" href="/topics/py-vm">虚拟机与字节码</a> · <a class="text-primary-cyan underline" href="/topics/py-objects">对象模型与内存</a> · <a class="text-primary-cyan underline" href="/topics/py-optimization">性能优化</a> · <a class="text-primary-cyan underline" href="/topics/cpp">C++ 概览</a>（对比）。</span><span slot="en">Related: <a class="text-primary-cyan underline" href="/topics/py-syntax">Syntax</a> · <a class="text-primary-cyan underline" href="/topics/py-stdlib">Stdlib</a> · <a class="text-primary-cyan underline" href="/topics/py-vm">VM & Bytecode</a> · <a class="text-primary-cyan underline" href="/topics/py-objects">Object Model</a> · <a class="text-primary-cyan underline" href="/topics/py-optimization">Performance</a> · <a class="text-primary-cyan underline" href="/topics/cpp">C++ Overview</a> (comparison).</span></Bilingual></p>
  </article>
</BaseLayout>

<script>
  // GIL 时间轴可视化
  const SVGNS = 'http://www.w3.org/2000/svg';
  const svg = document.getElementById('gil-svg') as unknown as SVGSVGElement;
  const gilBtns = document.querySelectorAll<HTMLButtonElement>('.gil-btn');

  interface Seg { x: number; w: number; type: 'run' | 'wait' | 'io'; }
  interface Thread { name: string; segs: Seg[]; }
  interface ModeData {
    titleZh: string; titleEn: string;
    threads: Thread[];
    concZh: string; concEn: string;
  }

  const MODES: Record<string, ModeData> = {
    cpu: {
      titleZh: 'CPU 密集：GIL 串行化多线程', titleEn: 'CPU-bound: GIL serializes threads',
      threads: [
        { name: 'Thread-1', segs: [{ x: 80, w: 340, type: 'run' }, { x: 420, w: 340, type: 'wait' }] },
        { name: 'Thread-2', segs: [{ x: 80, w: 340, type: 'wait' }, { x: 420, w: 340, type: 'run' }] },
      ],
      concZh: '两线程 CPU 密集任务串行执行，总耗时 ≈ 单线程的 2 倍，GIL 阻止并行加速',
      concEn: 'Two CPU-bound threads run serially; total time ≈ 2× single-thread — GIL blocks parallel speedup',
    },
    io: {
      titleZh: 'I/O 密集：GIL 在 I/O 时释放', titleEn: 'I/O-bound: GIL released during I/O',
      threads: [
        { name: 'Thread-1', segs: [{ x: 80, w: 80, type: 'run' }, { x: 160, w: 200, type: 'io' }, { x: 360, w: 80, type: 'run' }, { x: 440, w: 200, type: 'io' }, { x: 640, w: 80, type: 'run' }] },
        { name: 'Thread-2', segs: [{ x: 80, w: 80, type: 'wait' }, { x: 160, w: 200, type: 'run' }, { x: 360, w: 80, type: 'io' }, { x: 440, w: 200, type: 'run' }, { x: 640, w: 80, type: 'io' }] },
      ],
      concZh: 'I/O 等待时释放 GIL，Thread-2 趁机运行，两线程并发有效，吞吐量接近 2 倍',
      concEn: 'GIL released during I/O lets Thread-2 run; concurrent I/O boosts throughput ~2×',
    },
  };

  const COLORS: Record<string, { fill: string; stroke: string }> = {
    run: { fill: '#22D3EE', stroke: '#22D3EE' },
    wait: { fill: '#F8717144', stroke: '#F87171' },
    io: { fill: '#60A5FA44', stroke: '#60A5FA' },
  };
  const LABELS: Record<string, [string, string]> = {
    run: ['持有 GIL 执行', 'holds GIL'],
    wait: ['等待 GIL', 'waits for GIL'],
    io: ['I/O (释放 GIL)', 'I/O (releases GIL)'],
  };

  function lang(): 'zh' | 'en' { return document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh'; }

  function render(mode: string) {
    const data = MODES[mode];
    if (!data) return;
    svg.innerHTML = '';

    // 标题
    const title = document.createElementNS(SVGNS, 'text');
    title.setAttribute('x', '400'); title.setAttribute('y', '28');
    title.setAttribute('text-anchor', 'middle'); title.setAttribute('font-size', '15');
    title.setAttribute('font-weight', '700'); title.setAttribute('fill', '#22D3EE');
    title.textContent = lang() === 'en' ? data.titleEn : data.titleZh;
    svg.appendChild(title);

    // 时间轴底线
    const axis = document.createElementNS(SVGNS, 'line');
    axis.setAttribute('x1', '80'); axis.setAttribute('y1', '55');
    axis.setAttribute('x2', '760'); axis.setAttribute('y2', '55');
    axis.setAttribute('stroke', 'rgba(148,163,184,0.3)'); axis.setAttribute('stroke-width', '1.5');
    svg.appendChild(axis);

    // 线程行
    const rowY = [85, 135];
    const segH = 28;
    for (let i = 0; i < data.threads.length; i++) {
      const th = data.threads[i];
      const y = rowY[i];

      // 线程名
      const name = document.createElementNS(SVGNS, 'text');
      name.setAttribute('x', '70'); name.setAttribute('y', String(y + segH / 2 + 5));
      name.setAttribute('text-anchor', 'end'); name.setAttribute('font-size', '12');
      name.setAttribute('font-weight', '600'); name.setAttribute('fill', '#94A3B8');
      name.setAttribute('font-family', 'monospace');
      name.textContent = th.name;
      svg.appendChild(name);

      // 分段
      for (const seg of th.segs) {
        const c = COLORS[seg.type];
        const rect = document.createElementNS(SVGNS, 'rect');
        rect.setAttribute('x', String(seg.x)); rect.setAttribute('y', String(y));
        rect.setAttribute('width', String(seg.w)); rect.setAttribute('height', String(segH));
        rect.setAttribute('rx', '4'); rect.setAttribute('fill', c.fill);
        rect.setAttribute('stroke', c.stroke); rect.setAttribute('stroke-width', '1.5');
        svg.appendChild(rect);
      }
    }

    // 时间箭头
    const arrow = document.createElementNS(SVGNS, 'text');
    arrow.setAttribute('x', '760'); arrow.setAttribute('y', '50');
    arrow.setAttribute('font-size', '11'); arrow.setAttribute('fill', '#64748B');
    arrow.textContent = lang() === 'en' ? 'time →' : '时间 →';
    svg.appendChild(arrow);

    // 图例
    const legendY = 185;
    const legendItems: { type: string; x: number }[] = [
      { type: 'run', x: 120 }, { type: 'wait', x: 320 }, { type: 'io', x: 540 },
    ];
    for (const li of legendItems) {
      const c = COLORS[li.type];
      const sw = document.createElementNS(SVGNS, 'rect');
      sw.setAttribute('x', String(li.x)); sw.setAttribute('y', String(legendY));
      sw.setAttribute('width', '16'); sw.setAttribute('height', '12');
      sw.setAttribute('rx', '2'); sw.setAttribute('fill', c.fill);
      sw.setAttribute('stroke', c.stroke); sw.setAttribute('stroke-width', '1');
      svg.appendChild(sw);
      const lt = document.createElementNS(SVGNS, 'text');
      lt.setAttribute('x', String(li.x + 22)); lt.setAttribute('y', String(legendY + 10));
      lt.setAttribute('font-size', '11'); lt.setAttribute('fill', '#CBD5E1');
      lt.textContent = lang() === 'en' ? LABELS[li.type][1] : LABELS[li.type][0];
      svg.appendChild(lt);
    }

    // 结论
    const conc = document.createElementNS(SVGNS, 'text');
    conc.setAttribute('x', '400'); conc.setAttribute('y', '235');
    conc.setAttribute('text-anchor', 'middle'); conc.setAttribute('font-size', '12');
    conc.setAttribute('font-weight', '600'); conc.setAttribute('fill', '#F472B6');
    const concText = lang() === 'en' ? data.concEn : data.concZh;
    // 简单换行：按字符宽度估算
    const maxLen = 52;
    if (concText.length <= maxLen) {
      conc.textContent = concText;
      svg.appendChild(conc);
    } else {
      svg.appendChild(conc);
      conc.textContent = concText.slice(0, maxLen);
      const conc2 = document.createElementNS(SVGNS, 'text');
      conc2.setAttribute('x', '400'); conc2.setAttribute('y', '253');
      conc2.setAttribute('text-anchor', 'middle'); conc2.setAttribute('font-size', '12');
      conc2.setAttribute('font-weight', '600'); conc2.setAttribute('fill', '#F472B6');
      conc2.textContent = concText.slice(maxLen);
      svg.appendChild(conc2);
    }
  }

  function setActive(mode: string) {
    gilBtns.forEach(b => b.classList.toggle('btn-primary', b.dataset.mode === mode));
    render(mode);
  }
  gilBtns.forEach(b => b.addEventListener('click', () => setActive(b.dataset.mode!)));
  document.addEventListener('langchange', () => {
    const active = document.querySelector<HTMLButtonElement>('.gil-btn.btn-primary');
    render(active?.dataset.mode || 'cpu');
  });
  setActive('cpu');
</script>
