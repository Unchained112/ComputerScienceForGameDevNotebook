---
import { outline } from '../content/outline';
import SidebarItem from './SidebarItem.astro';
import Bilingual from './Bilingual.astro';
---
<nav class="sidebar-inner" aria-label="Outline">
  <p class="px-3 mb-2 text-xs uppercase tracking-wider text-ink-muted">
    <Bilingual><span slot="zh">大纲</span><span slot="en">Outline</span></Bilingual>
  </p>
  {outline.map((node) => <SidebarItem node={node} />)}
</nav>

<style>
  .sidebar-group-btn .caret {
    transition: transform 0.2s ease;
  }
  .sidebar-group-btn.open .caret {
    transform: rotate(90deg);
  }
  .sidebar-leaf.nav-link-active {
    border-left: 2px solid #22d3ee;
    background: linear-gradient(90deg, rgba(34, 211, 238, 0.12), transparent);
  }
</style>
