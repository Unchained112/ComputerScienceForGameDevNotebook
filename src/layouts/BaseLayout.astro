---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
}
const { title = 'CS·GameDev Notebook' } = Astro.props;
const home = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh" data-lang="zh">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${home}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Computer Science for Game Development — interactive notebook with visualizations." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      // 首屏渲染前应用已保存的语言/主题，避免闪烁
      (function () {
        try {
          var lang = localStorage.getItem('csnote-lang') || (navigator.language.indexOf('en') === 0 ? 'en' : 'zh');
          document.documentElement.setAttribute('data-lang', lang);
          var theme = localStorage.getItem('csnote-theme') || 'dark';
          if (theme === 'light') document.documentElement.classList.add('light');
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Nav />
    <div class="layout mx-auto max-w-7xl px-3 sm:px-6 grid gap-6 pb-16">
      <aside class="sidebar-wrap">
        <div class="sidebar-sticky glass p-3">
          <Sidebar />
        </div>
      </aside>
      <main class="content min-w-0">
        <slot />
      </main>
    </div>

    <style>
      .layout {
        grid-template-columns: 280px minmax(0, 1fr);
      }
      @media (max-width: 880px) {
        .layout {
          grid-template-columns: 1fr;
        }
        .sidebar-wrap {
          display: none;
        }
      }
      .sidebar-sticky {
        position: sticky;
        top: 84px;
        max-height: calc(100vh - 100px);
        overflow-y: auto;
      }
    </style>
  </body>
</html>
